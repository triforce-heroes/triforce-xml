  },
  {
    "reference": "dialog.IDD_REGISTER.5",
    "text": "&Clé d'enregistrement :",
  },
  {
    "reference": "dialog.IDD_REGISTER.6",
    "text": "&Adresse courriel :",
  },
  {
    "reference": "dialog.IDD_REGISTER.7",
    "text": "NB : Le nom et l'adresse courriel doivent être exactement comme indiqués dans le courriel d'enregistrement.",
  },
  {
    "reference": "dialog.IDD_REGISTER.8",
    "text": "Si vous rencontrez des problèmes, demandez de l'assistance à "support@mythicsoft.com".",
  },
  {
    "reference": "dialog.IDD_REGISTER.9",
    "text": "Entrez votre information d'enregistrement.",
  },
  {
