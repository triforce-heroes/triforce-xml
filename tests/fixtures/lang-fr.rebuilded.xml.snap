  },
  {
    "reference": "string.Ressource.92",
    "text": "Fermer l'aperçu d'impression\nAnnuler l'aperçu",
  },
  {
    "reference": "string.Ressource.93",
    "text": "Ce panneau affiche chaque fichier sélectionnés dans l'affichage de la liste des fichiers. Si vous faites une recherche par contenu, ce panneau affiche aussi des lignes trouvées dans les fichiers sélectionnés. Pour les options disponibles, utilisez le bouton droit de la souris pour faire apparaître le menu contextuel.",
  },
  {
    "reference": "string.Ressource.94",
    "text": "% s n'est pas un répertoire de recherche valide. Le nom du répertoire doit être un chemin valide, y compris la lettre de lecteur (par ex. : C:\Windows) OU un nom UNC correctement construit (par ex. : \\WORKSTATION\dossier_partagé \).",
  },
  {
    "reference": "string.Ressource.95",
    "text": "\nRechercher\nChercher\nChercher des fichiers (*.sea)\n.sea\nRechercher.Document\nChercher un document",
  },
  {
    "reference": "string.Ressource.96",
    "text": "Copier le(s) chemin(s) du/des fichier(s) sélectionné(s) dans le presse-papiers\nCopie le(s) chemin(s)",
  },
  {
    "reference": "string.Ressource.97",
    "text": "Ouvrir le dialogue des propriétés des\du fichier(s) sélectionné(s)\nOuvrir propriétés",
  },
