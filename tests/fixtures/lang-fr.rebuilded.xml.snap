  },
  {
    "reference": "string.Ressource.99",
    "text": "Tester le moteur d'expression régulière",
  },
  {
    "reference": "string.Ressource.100",
    "text": "Activer/désactiver le saut de ligne automatique lors de l'affichage des contenus\nSaut de ligne automatique",
