  {
    "reference": "dialog.IDD_EXPR_WIZ.caption",
    "text": "Création d'expression",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.1",
    "text": "survient :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.2",
    "text": "&Ajouter",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.3",
    "text": "&Modifier",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.4",
    "text": "&Supprimer",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.5",
    "text": "List2",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.6",
    "text": "Expression résultante",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.7",
    "text": "NB : "Glisser-déplacer" pour réorganiser les éléments",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.caption",
    "text": "Présentation de l'Assistant d'expression ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.1",
    "text": "Bienvenue dans l'Assistant d'expression. Cet assistant vous aidera à définir exactement ce que vous voulez faire.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.2",
    "text": "Les "Expressions Régulières" décrivent des canevas de concordance de chaînes. Très puissantes, elles découragent souvent les profanes.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.3",
    "text": "L'objectif de cet assistant est de simplifier les expressions régulières sans sacrifier leur puissance. Il vous aide à construire une expression en vous demandant de décrire ce que vous voulez en des termes compréhensibles.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.4",
    "text": "NB : ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.5",
    "text": "La note spécifique de recherche vient ici.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.6",
    "text": "&Ne plus afficher cette présentation.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.caption",
    "text": "Attention : Des caractères spéciaux sont entrés",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.1",
    "text": "&"Oui". Insérer les  "\" appropriés, car aucun des caractères que j'ai entrés ne doit être traité comme caractère spécial.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.2",
    "text": "&"Non". J'utilise délibérément des caractères spéciaux pour réaliser une recherche avancée.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.3",
    "text": "Une ou plusieurs des expressions entrées contient au moins un des caractères spéciaux suivants : ^$*?+.[]()|\ ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.4",
    "text": "Les caractères spéciaux sont utilisés dans les expressions régulières pour définir les règles de concordance de canevas et doivent être utilisés avec prudence. Si vous voulez chercher un caractère qui est aussi un caractère spécial, vous devez mettre une barre oblique inverse (\) avant le caractère.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.6",
    "text": "Par exemple :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.7",
    "text": "Pour chercher :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.8",
    "text": "l'expression serait :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.9",
    "text": "$400.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.10",
    "text": "\$400\.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.11",
    "text": "C'était quoi ?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.12",
    "text": "C'était quoi \?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.13",
    "text": "(12\4)*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.14",
    "text": "\(12\\4\)\*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.15",
    "text": "Pour chercher :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.16",
    "text": "Pour chercher :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.17",
    "text": "l'expression serait :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.18",
    "text": "l'expression serait :",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.19",
    "text": "Voulez-vous que l'Assistant d'expressions insère automatiquement un "\" devant tous les caractères spéciaux ?",
  },
  {
    "reference": "dialog.IDD_OPTIONS.caption",
    "text": "Options",
  },
  {
    "reference": "dialog.IDD_OPTIONS.1",
    "text": "Spécifie l'expression &NOT",
  },
  {
    "reference": "dialog.IDD_OPTIONS.2",
    "text": "&Respecter la casse",
  },
  {
    "reference": "dialog.IDD_OPTIONS.3",
    "text": "Respecter la &casse",
  },
  {
    "reference": "dialog.IDD_OPTIONS.4",
    "text": "Nom du fichier",
  },
  {
    "reference": "dialog.IDD_OPTIONS.5",
    "text": "Contenu",
  },
  {
    "reference": "dialog.IDD_OPTIONS.6",
    "text": "Examiner",
  },
  {
    "reference": "dialog.IDD_OPTIONS.7",
    "text": "Recherche améliorée de document",
  },
  {
    "reference": "dialog.IDD_OPTIONS.8",
    "text": "Documents Office/PDF",
  },
  {
    "reference": "dialog.IDD_OPTIONS_ADVANCED_LITE.1",
    "text": "Spécifie l'expression &NOT",
  },
  {
    "reference": "dialog.IDD_OPTIONS_ADVANCED_LITE.2",
    "text": "&Respecter la casse",
  },
