    "text": "Aide…",
  },
  {
    "reference": "dialog.IDD_ADVANCED.10",
    "text": "So&us-dossiers",
  },
  {
    "reference": "dialog.IDD_ADVANCED.11",
    "text": "Parcourir…",
  },
  {
