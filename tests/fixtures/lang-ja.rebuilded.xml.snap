%s",
  },
  {
    "reference": "string.Text.397",
    "text": "本当に検索フィルター '%s' を削除しますか?",
  },
  {
    "reference": "string.Text.398",
    "text": "IFilter",
  },
  {
    "reference": "string.Text.399",
    "text": "下部",
  },
  {
    "reference": "string.Text.400.regex",
    "text": "start",
  },
  {
    "reference": "string.Text.401.regex",
    "text": "today",
  },
  {
    "reference": "string.Text.402.regex",
    "text": "now",
  },
  {
    "reference": "string.Text.403.regex",
    "text": "s.*",
  },
  {
    "reference": "string.Text.404.regex",
    "text": "mi.*",
  },
  {
    "reference": "string.Text.405.regex",
    "text": "mo.*",
  },
  {
    "reference": "string.Text.406.regex",
    "text": "h.*",
  },
  {
    "reference": "string.Text.407.regex",
    "text": "d.*",
  },
  {
    "reference": "string.Text.408.regex",
    "text": "w.*",
  },
  {
    "reference": "string.Text.409.regex",
    "text": "y.*",
  },
  {
    "reference": "string.Text.410.regex",
    "text": "\b(today)|(start|end) *(?: +(?:the|of|this))* +(w|mo|y)[a-z]*",
  },
  {
    "reference": "string.Text.411.regex",
