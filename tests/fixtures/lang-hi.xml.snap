  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.7",
    "text": "सेफ़ मोड में चलाएं",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.8",
    "text": "इन्डेक्सिंग सर्विस फिल्टर का उपयोग करें (यदि उपलब्ध हो तो)",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.9",
    "text": "सक्रिय न होने पर कंटेन्ट सर्च से मिले फ़ाइल प्रकार को शामिल न करें",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSIONMAIN.caption",
    "text": "",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSIONMAIN.1",
    "text": "रीस्टोर करें...",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSIONMAIN.2",
    "text": "एक्स्टेंशन सेटिंग को इन्स्टॉल करने के समय के डिफ़ॉल्टों पर पूनः स्थापित करने के लिए नीचे का यह बटन दबाएं।",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSIONMAIN.3",
    "text": "एक्स्टेन्शन कोन्फिगरेशन पूनः स्थापित करें।",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSIONMAIN.4",
    "text": "यह कोन्फिगरेशन समुह एड्वान्स्ड फ़ाइल प्रक्रिया के एक्स्टेन्शन सेटिंग को नियंत्रित करता है।",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_GENERAL.caption",
    "text": "",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_GENERAL.1",
    "text": "इस कोन्फिगरेशन समुह में फ़ाइल लोकेटरर प्रो की खोजों को नियंत्रित करने के सेटिंग हैं।",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EDITOR.caption",
    "text": "",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EDITOR.1",
    "text": "इस कोन्फिगरेशन समुह से कंटेन्ट-व्यू के साथ काम करते समय कौन-सा संपादक उपयोग में आयेगा, यह नियंत्रित होता है।",
  },
  {
