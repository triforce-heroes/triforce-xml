  {
    "reference": "string.टेक्स्ट.1046",
    "text": "पैरामीटर के लिए कोई मान निर्दिष्ट नहीं: %s",
  },
  {
    "reference": "string.टेक्स्ट.1047",
    "text": "अमान्य मापदण्ड",
  },
  {
    "reference": "string.टेक्स्ट.1048",
    "text": "फ़ाइल संस्करण",
  },
  {
    "reference": "string.टेक्स्ट.1049",
    "text": "उत्पाद संस्करण",
  },
  {
    "reference": "string.टेक्स्ट.1050",
    "text": "यह सुविधा आपके सिस्टम व्यवस्थापक द्वारा अक्षम कर दी गई है।",
  },
  {
    "reference": "string.टेक्स्ट.1051",
    "text": "फ़ाइल नाम फ़ील्ड में वाइल्डकार्ड वर्ण होता है लेकिन अभिव्यक्ति प्रकार सादा पाठ पर सेट होता है।",
  },
  {
    "reference": "string.टेक्स्ट.1052",
    "text": "त्रुटि रिपोर्ट उत्पन्न करें",
  },
  {
    "reference": "string.टेक्स्ट.1053",
    "text": "क्या आप त्रुटि रिपोर्ट बनाना और भेजना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.1054",
    "text": "रिपोर्ट बनाओ",
  },
  {
    "reference": "string.टेक्स्ट.1055",
    "text": "नया सूचकांक बनाएं",
  },
  {
    "reference": "string.टेक्स्ट.1056",
    "text": "इससे पहले कि आप कोई अनुक्रमणिका खोज कर सकें, आपको एक अनुक्रमणिका बनानी होगी। क्या आप एक इंडेक्स बनाना चाहेंगे?",
  },
  {
    "reference": "string.टेक्स्ट.1057",
    "text": "कृपया वह अनुक्रमणिका चुनें जिसे आप खोजना चाहते हैं।",
  },
  {
    "reference": "string.टेक्स्ट.1058",
    "text": "नाम लंबाई",
  },
  {
    "reference": "string.टेक्स्ट.1059",
    "text": "कुल पथ लंबाई",
  },
  {
    "reference": "string.टेक्स्ट.1060",
    "text": "अनुक्रमणिका खोजने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.1061",
    "text": "खोज विफल",
  },
  {
    "reference": "string.टेक्स्ट.1062",
    "text": "रेटिंग",
  },
  {
    "reference": "string.टेक्स्ट.1063",
    "text": "अभिविन्यास",
  },
  {
    "reference": "string.टेक्स्ट.1064",
    "text": "फोकल लम्बाई",
  },
  {
    "reference": "string.टेक्स्ट.1065",
    "text": "ज़िप फ़ाइल",
  },
  {
    "reference": "string.टेक्स्ट.1066",
    "text": "सत्र",
  },
  {
    "reference": "string.टेक्स्ट.1067",
    "text": "कार्यस्थान",
  },
  {
    "reference": "string.टेक्स्ट.1068",
    "text": "छवि ओसीआर विफल",
  },
  {
    "reference": "string.टेक्स्ट.1069",
    "text": "ओसीआर के साथ छवि स्कैन करना",
  },
  {
    "reference": "string.टेक्स्ट.1070",
    "text": "अंतिम रीफ्रेश",
  },
  {
    "reference": "string.टेक्स्ट.1071",
    "text": "एंबेडेड वस्तु",
  },
  {
    "reference": "string.टेक्स्ट.1072",
    "text": "नवीनतम अद्यतन सफलतापूर्वक पूरा नहीं हुआ.",
  },
  {
    "reference": "string.टेक्स्ट.1073",
    "text": "इंडेक्स %APP_NAME% के नए संस्करण का उपयोग करके बनाया गया था, कृपया इंडेक्स विवरण देखने के लिए इस इंस्टॉलेशन को अपग्रेड करें। इंडेक्स को अपडेट करने से इंडेक्स फिर से बनेगा और %APP_NAME% के इस संस्करण में पुनर्स्थापित हो जाएगा।",
  },
  {
    "reference": "string.टेक्स्ट.1074",
    "text": "बैकअप विधि का उपयोग करते हुए प्राथमिक खोज विधि विफल रही।",
  },
  {
    "reference": "string.टेक्स्ट.1075",
    "text": "क्या आप क्लिपबोर्ड में संग्रहीत पंजीकरण जानकारी का उपयोग करना चाहेंगे?",
  },
  {
    "reference": "string.टेक्स्ट.1076",
    "text": "यह फ़ाइल पासवर्ड से सुरक्षित है।",
  },
]