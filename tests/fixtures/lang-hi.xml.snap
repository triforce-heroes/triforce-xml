    "reference": "string.टेक्स्ट.31",
    "text": "टैब विभाजित",
  },
  {
    "reference": "string.टेक्स्ट.32",
    "text": "फ़ाइल सूची खोलने में असमर्थ: ",
  },
  {
    "reference": "string.टेक्स्ट.34",
    "text": "फ़ाइल फोल्डर",
  },
  {
    "reference": "string.टेक्स्ट.35",
    "text": "ऑन",
  },
  {
    "reference": "string.टेक्स्ट.36",
    "text": "ऑफ़",
  },
  {
    "reference": "string.टेक्स्ट.37",
    "text": "SVN/HG/GIT/CVS मेटा डेटा फोल्डरों को न गीनें",
  },
  {
    "reference": "string.टेक्स्ट.38",
    "text": "प्रोग्राम फ़ाइल फोल्डरों को न गीनें",
  },
  {
    "reference": "string.टेक्स्ट.39",
    "text": "!$(ProgramFiles)",
  },
  {
    "reference": "string.टेक्स्ट.40",
    "text": "विन्डोज़ की सिस्टम फ़ाइलों को न गीनें",
  },
  {
    "reference": "string.टेक्स्ट.41",
    "text": "!$(WindowsFolder)",
  },
  {
    "reference": "string.टेक्स्ट.42",
    "text": "रीसायकल बिन को न गीनें",
  },
  {
    "reference": "string.टेक्स्ट.43",
    "text": "हिस्टरी मिटाई जा रही है।",
  },
  {
    "reference": "string.टेक्स्ट.44",
    "text": "एड्वान्स्ड",
  },
  {
    "reference": "string.टेक्स्ट.45",
    "text": "फ़ाइल सूची",
  },
  {
    "reference": "string.टेक्स्ट.46",
    "text": "फोल्डर",
  },
  {
    "reference": "string.टेक्स्ट.47",
    "text": "जन्क्शन पोइन्ट्स",
  },
  {
    "reference": "string.टेक्स्ट.48",
    "text": "थ्रेड/प्राथमिकता",
  },
  {
    "reference": "string.टेक्स्ट.49",
    "text": "XSLT प्रोसेसर",
  },
  {
    "reference": "string.टेक्स्ट.50",
    "text": "संपादक",
  },
  {
    "reference": "string.टेक्स्ट.51",
    "text": "डिफॉल्ट संपादक",
  },
  {
    "reference": "string.टेक्स्ट.52",
    "text": "बाह्य संपादक",
  },
  {
    "reference": "string.टेक्स्ट.53",
    "text": "आंतरिक व्यूअर",
  },
  {
    "reference": "string.टेक्स्ट.54",
    "text": "निर्दिष्ट प्रोग्राम आइडी से XSL पार्सर बनाने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.55",
    "text": "एप्लिकेशन फ़ाइलें (*.exe)|*.exe|सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.56",
    "text": "फ़ाइल ब्राउज़र खोलते समय त्रुटि। ब्राउज़ करने से पहले यह निश्चित करें कि फ़ाइल का नाम वैध है।",
  },
  {
    "reference": "string.टेक्स्ट.57",
    "text": "इससे सभी एक्सटेन्शन सेटिंग्स अपनी मूल स्थापना स्थिति में लौट जाएंगी। क्या आप निश्चित हैं ?",
  },
  {
    "reference": "string.टेक्स्ट.58",
    "text": "एक्सटेन्शन रीसेट हो रहे हैं",
  },
  {
    "reference": "string.टेक्स्ट.59",
    "text": "फ़ाइल मिलने पर प्ले करने के लिए साउन्ड निर्दिष्ट करें।",
  },
  {
    "reference": "string.टेक्स्ट.60",
    "text": "खोज पूरी होने पर प्ले करने के लिए साउन्ड निर्दिष्ट करें।",
  },
  {
    "reference": "string.टेक्स्ट.61",
    "text": "साउन्ड प्ले करने में असमर्थ। साउन्ड फ़ाइल करप्ट हो सकती है, या हो सकता है कि वह एक वैध वेवफोर्म में न हो।",
  },
  {
    "reference": "string.टेक्स्ट.62",
    "text": "कृपयां प्ले करने के लिए वैध साउन्ड फ़ाइल निर्दिष्ट करें।",
  },
  {
    "reference": "string.टेक्स्ट.63",
    "text": "साउन्ड फ़ाइलें (*.wav)|*.wav|सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.64",
    "text": "साउन्ड फ़ाइल खोजने में असमर्थ।",
  },
  {
    "reference": "string.टेक्स्ट.65",
    "text": "प्रकार",
  },
  {
    "reference": "string.टेक्स्ट.66",
    "text": "स्थिति",
  },
  {
    "reference": "string.टेक्स्ट.67",
    "text": "संबंधित आईफिल्टर",
  },
  {
    "reference": "string.टेक्स्ट.68",
    "text": "फ़ाइल लोकेटर प्रो USB डिवाइस से चलने के लिए कोन्फिगर्ड है। शेल सेटिंग सेट नहीं हो सकते हैं।",
  },
  {
    "reference": "string.टेक्स्ट.69",
    "text": "एक्स्प्रेशन्स",
  },
  {
    "reference": "string.टेक्स्ट.70",
    "text": "बूलिअन एक्सप्रेशन्स",
  },
  {
    "reference": "string.टेक्स्ट.71",
    "text": "Wildcards",
  },
  {
    "reference": "string.टेक्स्ट.72",
    "text": "सामान्य एक्सप्रेशन्स",
  },
  {
    "reference": "string.टेक्स्ट.73",
    "text": "फ़ाइल हैशिंग",
  },
  {
    "reference": "string.टेक्स्ट.74",
    "text": "UTF-8 डिफॉल्ट फॉर्मेट",
  },
  {
    "reference": "string.टेक्स्ट.75",
    "text": "एक्सप्रेशन्स",
  },
  {
    "reference": "string.टेक्स्ट.76",
    "text": "सामान्य",
  },
  {
    "reference": "string.टेक्स्ट.77",
    "text": "हिस्टरी",
  },
  {
    "reference": "string.टेक्स्ट.78",
    "text": "डिस्प्ले",
  },
  {
    "reference": "string.टेक्स्ट.79",
    "text": "कैरेक्टर प्रोसेसिंग",
  },
  {
    "reference": "string.टेक्स्ट.80",
    "text": "शेल इन्टीग्रेशन",
  },
  {
    "reference": "string.टेक्स्ट.81",
    "text": "साउन्ड/एलर्ट्स",
  },
  {
    "reference": "string.टेक्स्ट.82",
    "text": "युज़र इन्टरफ़ेस",
  },
  {
    "reference": "string.टेक्स्ट.83",
    "text": "कोन्फिगरेशन जानकारी लागु हो रही है।",
  },
  {
    "reference": "string.टेक्स्ट.84",
    "text": "इससे सभी कोन्फिगरेशन सेटिंग्स स्थापना समय की सेटिंग्स पर सेट हो जाएंगीं। क्या आप निश्चित हैं?",
  },
  {
    "reference": "string.टेक्स्ट.85",
    "text": "कोन्फिगरेशन रीसेट हो रहे हैं।",
  },
  {
    "reference": "string.टेक्स्ट.86",
    "text": "वर्णन",
  },
  {
    "reference": "string.टेक्स्ट.87",
    "text": "फिल्टर मूल्य",
  },
  {
    "reference": "string.टेक्स्ट.88",
    "text": "फ़ाइल से डाटा लिया जा रहा है।...",
  },
  {
    "reference": "string.टेक्स्ट.89",
    "text": "एकल उपयोगकर्ता लाइसेन्स",
  },
  {
    "reference": "string.टेक्स्ट.90",
    "text": "संस्थाकीय एकाधिक-साइट लाइसेन्स (%s उपयोगकर्ताओं तक)",
  },
  {
    "reference": "string.टेक्स्ट.91",
    "text": "संस्थाकीय एकाधिक-साइट लाइसेन्स (असीमित उपयोगकर्ता)",
  },
  {
    "reference": "string.टेक्स्ट.92",
    "text": "एकाधिक उपयोगकर्ता लाइसेन्स: %s लाइसेन्स",
  },
  {
    "reference": "string.टेक्स्ट.93",
    "text": "पंजीकरण कोड: 
%s",
  },
  {
    "reference": "string.टेक्स्ट.94",
    "text": "सहायता/निःशुल्क अपग्रेड इस तारीख़़ तक: %s
",
  },
  {
    "reference": "string.टेक्स्ट.95",
    "text": "परीक्षण लाइसेन्स खत्म। इस प्रोडक्ट का कानुनन उपयोग जारी रखने के लिए पंजीकरण आवश्यक है।",
  },
  {
    "reference": "string.टेक्स्ट.96",
    "text": "परीक्षण लाइसेन्स, बाकी दिन: %d.",
  },
  {
    "reference": "string.टेक्स्ट.97",
    "text": "केस मैच करें",
  },
  {
    "reference": "string.टेक्स्ट.98",
    "text": "लगातार खोज फिल्टर्स",
  },
  {
    "reference": "string.टेक्स्ट.99",
    "text": "माप (byte)",
  },
  {
    "reference": "string.टेक्स्ट.100",
    "text": "माप (kB)",
  },
  {
    "reference": "string.टेक्स्ट.101",
    "text": "माप (MB)",
  },
  {
    "reference": "string.टेक्स्ट.102",
    "text": "माप (GB)",
  },
  {
    "reference": "string.टेक्स्ट.103",
    "text": "समाप्त",
  },
  {
    "reference": "string.टेक्स्ट.104",
    "text": "नया संस्करण उपलब्ध",
  },
  {
    "reference": "string.टेक्स्ट.105",
    "text": "कोई अपडेट नहीं",
  },
  {
    "reference": "string.टेक्स्ट.106",
    "text": "नयी खोज",
  },
  {
    "reference": "string.टेक्स्ट.107",
    "text": "दिखाएं",
  },
  {
    "reference": "string.टेक्स्ट.108",
    "text": "क्राइटिरिया फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.109",
    "text": "Command line search was not successful.",
  },
  {
    "reference": "string.टेक्स्ट.110",
    "text": "फ़ाइल(लें) मिली",
  },
  {
    "reference": "string.टेक्स्ट.111",
    "text": "यह वैध तारीख़/समय फॉर्मेट नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.112",
    "text": "कोई फ़ाइल नहीं चुनी गई",
  },
  {
    "reference": "string.टेक्स्ट.113",
    "text": "आंकड़ें खोजें",
  },
  {
    "reference": "string.टेक्स्ट.114",
    "text": "सारांश",
  },
  {
    "reference": "string.टेक्स्ट.115",
    "text": "थम्बनेल",
  },
  {
    "reference": "string.टेक्स्ट.116",
    "text": "त्रुटि",
  },
  {
    "reference": "string.टेक्स्ट.117",
    "text": "बदलने की तारीख़",
  },
  {
    "reference": "string.टेक्स्ट.118",
    "text": "बनाने की तारीख़",
  },
  {
    "reference": "string.टेक्स्ट.119",
    "text": "अंतिम बार देखने की तारीख़",
  },
  {
    "reference": "string.टेक्स्ट.120",
    "text": "अभी",
  },
  {
    "reference": "string.टेक्स्ट.121",
    "text": "मिनट की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.122",
    "text": "घंटे की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.123",
    "text": "दिन की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.124",
    "text": "मिनट का अंत",
  },
  {
    "reference": "string.टेक्स्ट.125",
    "text": "घंटे का अंत",
  },
  {
    "reference": "string.टेक्स्ट.126",
    "text": "दिन का अंत",
  },
  {
    "reference": "string.टेक्स्ट.133",
    "text": "%s यह समय का वैध फॉर्मेट नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.134",
    "text": "अनपेक्षित एक्स्प्रेशन प्रकार",
  },
  {
    "reference": "string.टेक्स्ट.135",
    "text": "पता नहीं",
  },
  {
    "reference": "string.टेक्स्ट.136",
    "text": "कोई भी कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.137",
    "text": "कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.138",
    "text": "इसमें से कोई भी कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.139",
    "text": "इसके सिवा कोई भी कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.140",
    "text": "वाक्यांश",
  },
  {
    "reference": "string.टेक्स्ट.141",
    "text": "खाली जगह",
  },
  {
    "reference": "string.टेक्स्ट.142",
    "text": "कोई भी अंकीय कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.143",
    "text": "कोई भी टेक्स्ट कैरेक्टर",
  },
  {
    "reference": "string.टेक्स्ट.144",
    "text": "ज़ीरो या एक बार",
  },
  {
    "reference": "string.टेक्स्ट.145",
    "text": "ज़ीरो या एकाधिक बार",
  },
  {
    "reference": "string.टेक्स्ट.146",
    "text": "केवल एक बार",
  },
  {
    "reference": "string.टेक्स्ट.147",
    "text": "एक या एकाधिक बार",
  },
  {
    "reference": "string.टेक्स्ट.148",
    "text": "इसके बाद यह हो",
  },
  {
    "reference": "string.टेक्स्ट.149",
    "text": "होता है",
  },
  {
    "reference": "string.टेक्स्ट.150",
    "text": "फ़ाइलनेम एक्स्प्रेशन विज़ार्ड",
  },
  {
    "reference": "string.टेक्स्ट.151",
    "text": "फेवरेट को संपादित करें",
  },
  {
    "reference": "string.टेक्स्ट.152",
    "text": "सहेजें",
  },
  {
    "reference": "string.टेक्स्ट.153",
    "text": "दिखा रहा है: %s of %s",
  },
  {
    "reference": "string.टेक्स्ट.154",
    "text": "लोड रहा है...",
  },
  {
    "reference": "string.टेक्स्ट.155",
    "text": "लोड हो चुका है: %s",
  },
  {
    "reference": "string.टेक्स्ट.156",
    "text": "अज्ञात फेवरेट",
  },
  {
    "reference": "string.टेक्स्ट.157",
    "text": "फेवरेट की खोज की तैयारी निष्फल: ",
  },
  {
    "reference": "string.टेक्स्ट.158",
    "text": "फेवरेट पढ़ रहा है",
  },
  {
    "reference": "string.टेक्स्ट.159",
    "text": "फेवरेट मिट रहा है",
  },
  {
    "reference": "string.टेक्स्ट.160",
    "text": "फेवरेट संपादित हो रहा है",
  },
  {
    "reference": "string.टेक्स्ट.161",
    "text": "टैग्स",
  },
  {
    "reference": "string.टेक्स्ट.162",
    "text": "खोज",
  },
  {
    "reference": "string.टेक्स्ट.163",
    "text": "फेवरेट सहेजा जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.164",
    "text": "फेवरेट फोल्डर खुल रहा है",
  },
  {
    "reference": "string.टेक्स्ट.165",
    "text": "खोज क्राइटिरिया प्राप्त करने में असमर्थ। असफल जोड़ें।",
  },
  {
    "reference": "string.टेक्स्ट.166",
    "text": "फेवरेट में जोड़ने लायक खोज को बनाएं या खोलें।",
  },
  {
    "reference": "string.टेक्स्ट.167",
    "text": "Trial period has expired. You need to either purchase a license or switch to the Free feature set.",
  },
  {
    "reference": "string.टेक्स्ट.168",
    "text": "कोन्फिगरेशन सेटिंग बदली जा रही है",
  },
  {
    "reference": "string.टेक्स्ट.169",
    "text": "The registration key has either been deleted or is unavailable. Please contact support@mythicsoft.com for more information.",
  },
  {
    "reference": "string.टेक्स्ट.170",
    "text": "कोन्फिगरेशन फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.171",
    "text": "हिस्टरी कोन्फिगरेशन फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.172",
    "text": "",
  },
  {
    "reference": "string.टेक्स्ट.173",
    "text": "फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.174",
    "text": "फ़ाइल खुल रही है",
  },
  {
    "reference": "string.टेक्स्ट.175",
    "text": "विज़ुअल स्टुडियों में फ़ाइल खोलने में असमर्थ। अधिक जानकारी के लिए कृपया लॉग फ़ाइल चेक करें।",
  },
  {
    "reference": "string.टेक्स्ट.176",
    "text": "कोई बाह्य संपादक निर्दिष्ट नहीं है। क्या आप अभी निर्दिष्ट करना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.178",
    "text": "बाह संपदक शुरू करने में त्रुटि। 

%s",
  },
  {
    "reference": "string.टेक्स्ट.179",
    "text": "खोज लोड नहीं हो सका",
  },
  {
    "reference": "string.टेक्स्ट.180",
    "text": "'-%s' कमान्ड लाइन फ्लैग के लिए मूल्य की आवश्यकता, लेकिन कुछ दिया नहीं गया है।",
  },
  {
    "reference": "string.टेक्स्ट.181",
    "text": "'-%s' कमान्ड लाइन फ्लैग वैध नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.182",
    "text": "अवैध तारीख़ फॉर्मेट: %s",
  },
  {
    "reference": "string.टेक्स्ट.183",
    "text": "अनपेक्षित कमान्ड लाइन पैरामीटर: %s",
  },
  {
    "reference": "string.टेक्स्ट.184",
    "text": "चल रहा है",
  },
  {
    "reference": "string.टेक्स्ट.185",
    "text": "खोज शुरू हो रहा है",
  },
  {
    "reference": "string.टेक्स्ट.186",
    "text": "**लोडिंग असफल **

लोड करने में असफल: %s

कृपया जांचे की फ़ाइल अभी भी मौजूद है तथा उसे खोलने के लिए आपके पास उपयुक्त सुरक्षा अधिकार हैं।

अधिक जानकारी के लिए कृपया तकनीकी सहायता से संपर्क करें तथा इस त्रुटि का पाठ तथा फोल्डर में स्थित अन्य लॉग फ़ाइलें भी भेजें।:
%s

अधिक जानकारी:
%s
",
  },
  {
    "reference": "string.टेक्स्ट.189",
    "text": "फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.190",
    "text": "रोक दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.191",
    "text": "पूरा हो गया",
  },
  {
    "reference": "string.टेक्स्ट.192",
    "text": "खोज के दौरान त्रुटि। यदि समस्या जारी रहती है, तो कृपया तकनीकी सहायता से संपर्क करें।",
  },
  {
    "reference": "string.टेक्स्ट.193",
    "text": "कन्टेन्ट्स व्यू",
  },
  {
    "reference": "string.टेक्स्ट.194",
    "text": "चयन बदला जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.195",
    "text": "खोज परिणाम ऑपरेशन सहेजा जा रहा है।",
  },
  {
    "reference": "string.टेक्स्ट.197",
    "text": "%s में ",
  },
  {
    "reference": "string.टेक्स्ट.198",
    "text": "क्राइटिरिया फ़ाइल खोलने में असमर्थ। कृपया जांचे की यह वैध क्राइटिरिया फ़ाइल है तथा फ़ाइल लोकेटर प्रो के पुराने संस्करण से नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.199",
    "text": "आप फेवरेट को ओवरराइट कर रहे हैं। क्या आप निश्चित हैं?",
  },
  {
    "reference": "string.टेक्स्ट.200",
    "text": "%s %s मिले।",
  },
  {
    "reference": "string.टेक्स्ट.201",
    "text": "खोज समाप्त - %s %s मिले",
  },
  {
    "reference": "string.टेक्स्ट.202",
    "text": "व्यू",
  },
  {
    "reference": "string.टेक्स्ट.203",
    "text": "फेवरेट्स",
  },
  {
    "reference": "string.टेक्स्ट.204",
    "text": "त्रुटि सूची",
  },
  {
    "reference": "string.टेक्स्ट.205",
    "text": "रोक दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.206",
    "text": "खोज समय",
  },
  {
    "reference": "string.टेक्स्ट.208",
    "text": "वर्तमान खोज ",
  },
  {
    "reference": "string.टेक्स्ट.209",
    "text": "मूल खोज",
  },
  {
    "reference": "string.टेक्स्ट.210",
    "text": "दिखाया गया",
  },
  {
    "reference": "string.टेक्स्ट.211",
    "text": "मिले",
  },
  {
    "reference": "string.टेक्स्ट.212",
    "text": "दिखा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.213",
    "text": "चयन किया",
  },
  {
    "reference": "string.टेक्स्ट.215",
    "text": "आइटम",
  },
  {
    "reference": "string.टेक्स्ट.216",
    "text": "मिला",
  },
  {
    "reference": "string.टेक्स्ट.218",
    "text": "%s MB",
  },
  {
    "reference": "string.टेक्स्ट.219",
    "text": "%s फ़ाइलें मिली",
  },
  {
    "reference": "string.टेक्स्ट.220",
    "text": "फ़ाइल लोकेटर प्रो का नया संस्करण उपलब्ध है। क्या आप जानकारी चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.221",
    "text": "पंजीकृत! पंजीकरण के लिए धन्यवाद।",
  },
  {
    "reference": "string.टेक्स्ट.222",
    "text": "पंजीकरण कूंजी अवैध है। कृपया यह जांचें कि पंजीकरण के ईमेल में दर्शायी गई जानकारी को ही यहां प्रविष्ट किया गया है।",
  },
  {
    "reference": "string.टेक्स्ट.225",
    "text": "परिणाम सहेजने के लिए वैध फ़ाइलनाम बताएं।",
  },
  {
    "reference": "string.टेक्स्ट.226",
    "text": "वैध ट्रान्स्फोर्म फ़ाइल का नाम बताएं।",
  },
  {
    "reference": "string.टेक्स्ट.227",
    "text": "खोज परिणाम।",
  },
  {
    "reference": "string.टेक्स्ट.228",
    "text": "सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.229",
    "text": "कस्टम फॉर्मेट फ़ाइल वैध नहीं है। यह जांचें कि फ़ाइल मौजूद है तथा आपके पास उचित सुरक्षा अधिकार हैं।

",
  },
  {
    "reference": "string.टेक्स्ट.230",
    "text": "XSL (*.xsl)|*.xsl|सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.231",
    "text": "फ़ाइल चयन डायलॉग खोलने में असमर्थ: %d",
  },
  {
    "reference": "string.टेक्स्ट.232",
    "text": "परीक्षण सफल।",
  },
  {
    "reference": "string.टेक्स्ट.233",
    "text": "खोजा गया",
  },
  {
    "reference": "string.टेक्स्ट.234",
    "text": "जांचा गया",
  },
  {
    "reference": "string.टेक्स्ट.235",
    "text": "स्थिति",
  },
  {
    "reference": "string.टेक्स्ट.236",
    "text": "शुरू नहीं किया गया",
  },
  {
    "reference": "string.टेक्स्ट.237",
    "text": "स्थगित",
  },
  {
    "reference": "string.टेक्स्ट.238",
    "text": "पुनः शुरू",
  },
  {
    "reference": "string.टेक्स्ट.240",
    "text": "%sMb of %sMb",
  },
  {
    "reference": "string.टेक्स्ट.242",
    "text": "फिल्टरिंग",
  },
  {
    "reference": "string.टेक्स्ट.243",
    "text": "खोज रहा है ",
  },
  {
    "reference": "string.टेक्स्ट.244",
    "text": "शुरू",
  },
  {
    "reference": "string.टेक्स्ट.245",
    "text": "टेक्स्ट में एक्स्प्रेशन पाया गया।
एक्स्प्रेशन शुरू: %d
एक्स्प्रेशन लंबाई: %d
मिला: %s",
  },
  {
    "reference": "string.टेक्स्ट.246",
    "text": "परिणाम सूची खाली",
  },
  {
    "reference": "string.टेक्स्ट.247",
    "text": "टेक्स्ट में एक्स्प्रेशन नहीं मिला।",
  },
  {
    "reference": "string.टेक्स्ट.248",
    "text": "पंजीकरण फ़ाइल अवैध।",
  },
  {
    "reference": "string.टेक्स्ट.249",
    "text": "पंजीकरण जानकारी नहीं मिली।",
  },
  {
    "reference": "string.टेक्स्ट.250",
    "text": "पंजीकरण कुंजी अवधि समाप्त।",
  },
  {
    "reference": "string.टेक्स्ट.251",
    "text": "फ़ाइल लोकेटर प्रो की-बोर्ड हूक",
  },
  {
    "reference": "string.टेक्स्ट.256",
    "text": "स्थापना लॉग शुरू होने में असमर्थ। कृपया दोबारा स्थापित करें। यदि समस्या जारी रहे, तो फ़ाइल लोकेटर प्रो तकनीकी सहाता से संपर्क करें।",
  },
  {
    "reference": "string.टेक्स्ट.258",
    "text": "कॉपी करें",
  },
  {
    "reference": "string.टेक्स्ट.259",
    "text": "पाथ कॉपी करें",
  },
  {
    "reference": "string.टेक्स्ट.260",
    "text": "कट करें",
  },
  {
    "reference": "string.टेक्स्ट.261",
    "text": "मिटाएं",
  },
  {
    "reference": "string.टेक्स्ट.262",
    "text": "यहां एक्स्प्लोर करें...",
  },
  {
    "reference": "string.टेक्स्ट.263",
    "text": "विशेषताएं",
  },
  {
    "reference": "string.टेक्स्ट.264",
    "text": "चयनित में खोजें",
  },
  {
    "reference": "string.टेक्स्ट.265",
    "text": "परिणाम सूची में खोजें",
  },
  {
    "reference": "string.टेक्स्ट.266",
    "text": "%s कन्टेन्ट्स व्यू",
  },
  {
    "reference": "string.टेक्स्ट.267",
    "text": "छिपाएं",
  },
  {
    "reference": "string.टेक्स्ट.268",
    "text": "
ये खोज डायरेक्टिरियां वैध नहीं है:

",
  },
  {
    "reference": "string.टेक्स्ट.269",
    "text": "
डायरेक्टरी नाम में वैध पथ तथा ड्राइव अक्षर (जैसे, C:\Windows) या एक उपयुक्त UNC नाम आवश्यक है। (जैसे, \\WORKSTATION\Shared_Folder).",
  },
  {
    "reference": "string.टेक्स्ट.272",
    "text": "मैक्रो लोड हो रहे हैं",
  },
  {
    "reference": "string.टेक्स्ट.273",
    "text": "स्क्रिप्ट पार्सिंग असफल:
",
  },
  {
    "reference": "string.टेक्स्ट.274",
    "text": "स्क्रिप्टिंग इंजन बनाने में समस्या।",
  },
  {
    "reference": "string.टेक्स्ट.275",
    "text": "(कोई विषय नहीं)",
  },
  {
    "reference": "string.टेक्स्ट.276",
    "text": "(अज्ञात)",
  },
  {
    "reference": "string.टेक्स्ट.277",
    "text": "बनाया",
  },
  {
    "reference": "string.टेक्स्ट.278",
    "text": "संपर्क",
  },
  {
    "reference": "string.टेक्स्ट.279",
    "text": "स्थान",
  },
  {
    "reference": "string.टेक्स्ट.280",
    "text": "तारीख़़",
  },
  {
    "reference": "string.टेक्स्ट.281",
    "text": "से",
  },
  {
    "reference": "string.टेक्स्ट.282",
    "text": "सादर",
  },
  {
    "reference": "string.टेक्स्ट.283",
    "text": "(खाली)",
  },
  {
    "reference": "string.टेक्स्ट.284",
    "text": "(प्राप्तकर्ता सूची लोड नहीं हुई- अधिक जानकारी के लिए तकनीकी सहायता से संपर्क करें।)
",
  },
  {
    "reference": "string.टेक्स्ट.285",
    "text": "प्राप्तकर्ता",
  },
  {
    "reference": "string.टेक्स्ट.286",
    "text": "प्रेषक",
  },
  {
    "reference": "string.टेक्स्ट.287",
    "text": "विषय",
  },
  {
    "reference": "string.टेक्स्ट.288",
    "text": "
संदेश बनाने मके दौरान त्रुटि: ",
  },
  {
    "reference": "string.टेक्स्ट.289",
    "text": "",
  },
  {
    "reference": "string.टेक्स्ट.290",
    "text": "एट्रिब्यूट",
  },
  {
    "reference": "string.टेक्स्ट.291",
    "text": "फ़ाइल माप",
  },
  {
    "reference": "string.टेक्स्ट.292",
    "text": "छोड़े गए एक्स्टेन्शन्स",
  },
  {
    "reference": "string.टेक्स्ट.294",
    "text": "त्रुटि की जानकारी भेजी गई, लेकिन कोई विवरण नहीं दिया गया।",
  },
  {
    "reference": "string.टेक्स्ट.295",
    "text": "कन्टेन्ट्स वेलिडेशन स्क्रिप्ट इसके साथ असफल: ",
  },
  {
    "reference": "string.टेक्स्ट.296",
    "text": "सेकन्ड",
  },
  {
    "reference": "string.टेक्स्ट.297",
    "text": "घंटा",
  },
  {
    "reference": "string.टेक्स्ट.298",
    "text": "मिनट",
  },
  {
    "reference": "string.टेक्स्ट.299",
    "text": "आज",
  },
  {
    "reference": "string.टेक्स्ट.300",
    "text": "सप्ताह की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.301",
    "text": "महीने की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.302",
    "text": "साल की शुरूआत",
  },
  {
    "reference": "string.टेक्स्ट.303",
    "text": "सप्ताह का अंत",
  },
  {
    "reference": "string.टेक्स्ट.304",
    "text": "महीने का अंत",
  },
  {
    "reference": "string.टेक्स्ट.305",
    "text": "साक का अंत",
  },
  {
    "reference": "string.टेक्स्ट.306",
    "text": "दिन",
  },
  {
    "reference": "string.टेक्स्ट.307",
    "text": "सप्ताह",
  },
  {
    "reference": "string.टेक्स्ट.308",
    "text": "महीना",
  },
  {
    "reference": "string.टेक्स्ट.309",
    "text": "साल",
  },
  {
    "reference": "string.टेक्स्ट.310",
    "text": "फ़ाइल पुनः प्राप्त करें...",
  },
  {
    "reference": "string.टेक्स्ट.311",
    "text": "आइटम नेम वेलिडेशन स्क्रिप्ट तैयार हो रही है: %s",
  },
  {
    "reference": "string.टेक्स्ट.312",
    "text": "आइटम नेम वेलिडेशन स्क्रिप्ट इसके साथ असफलः ",
  },
  {
    "reference": "string.टेक्स्ट.313",
    "text": "हां",
  },
  {
    "reference": "string.टेक्स्ट.314",
    "text": "न",
  },
  {
    "reference": "string.टेक्स्ट.315",
    "text": "फ़ाइल नेम एक्स्प्रेशन",
  },
  {
    "reference": "string.टेक्स्ट.316",
    "text": "फ़ाइल नेम - केस मैच करें",
  },
  {
    "reference": "string.टेक्स्ट.317",
    "text": "कन्टेन्ट खोज",
  },
  {
    "reference": "string.टेक्स्ट.318",
    "text": "शामिल टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.319",
    "text": "कन्टेन्ट एक्स्प्रेशन",
  },
  {
    "reference": "string.टेक्स्ट.320",
    "text": "कन्टेन्ट - केस मैच करें",
  },
  {
    "reference": "string.टेक्स्ट.321",
    "text": "फ़ाइल स्पैन करें",
  },
  {
    "reference": "string.टेक्स्ट.322",
    "text": "यहां देखें",
  },
  {
    "reference": "string.टेक्स्ट.323",
    "text": "सब फोल्डर",
  },
  {
    "reference": "string.टेक्स्ट.324",
    "text": "एक्स्प्रेशन में देखें",
  },
  {
    "reference": "string.टेक्स्ट.325",
    "text": "इसके बाद बदला हुआ",
  },
  {
    "reference": "string.टेक्स्ट.326",
    "text": "इसके पहले बदला हुआ",
  },
  {
    "reference": "string.टेक्स्ट.327",
    "text": "इसके बाद देखा गया",
  },
  {
    "reference": "string.टेक्स्ट.328",
    "text": "इसके पहले देखा गया",
  },
  {
    "reference": "string.टेक्स्ट.329",
    "text": "इसके बाद बनाया गया",
  },
  {
    "reference": "string.टेक्स्ट.330",
    "text": "इसके पहले बनाया गया",
  },
  {
    "reference": "string.टेक्स्ट.331",
    "text": "इससे बड़ा",
  },
  {
    "reference": "string.टेक्स्ट.332",
    "text": "इससे छोटा",
  },
  {
    "reference": "string.टेक्स्ट.333",
    "text": "शामिल टेक्स्ट सक्रिय स्क्रिप्टिंग उन बूलिअन खोजों द्वारा समर्थित नहीं हैं जो संपूर्ण फ़ाइल में एक्सप्रेशन से मेल खाते हों।  विकल्प टैब में 'पंक्ति दर पंक्ति' पर सेट करें।",
  },
  {
    "reference": "string.टेक्स्ट.334",
    "text": "कन्टेन्ट्स खोज मूल्य:",
  },
  {
    "reference": "string.टेक्स्ट.335",
    "text": "फ़ाइलनेम फिल्टर:",
  },
  {
    "reference": "string.टेक्स्ट.336",
    "text": "कोई स्क्रिप्ट प्रकार निर्दिष्ट नहीं",
  },
  {
    "reference": "string.टेक्स्ट.337",
    "text": "स्क्रिप्ट फ़ाइल उपलब्ध नहीं या खुल नहीं रही है।",
  },
  {
    "reference": "string.टेक्स्ट.338",
    "text": "स्क्रिप्ट का नाम निर्दिष्ट नहीं",
  },
  {
    "reference": "string.टेक्स्ट.339",
    "text": "स्क्रिप्ट पथ:",
  },
  {
    "reference": "string.टेक्स्ट.340",
    "text": "इंजन:",
  },
  {
    "reference": "string.टेक्स्ट.341",
    "text": "कस्टम पैरामीटर्स:",
  },
  {
    "reference": "string.टेक्स्ट.342",
    "text": "आर्काइव्ज़",
  },
  {
    "reference": "string.टेक्स्ट.343",
    "text": "कम्प्रेस्ड",
  },
  {
    "reference": "string.टेक्स्ट.344",
    "text": "एन्क्रिप्टिड",
  },
  {
    "reference": "string.टेक्स्ट.345",
    "text": "फोल्डर",
  },
  {
    "reference": "string.टेक्स्ट.346",
    "text": "ऑफ़लाइन",
  },
  {
    "reference": "string.टेक्स्ट.347",
    "text": "केवल पढ़ने के लिए",
  },
  {
    "reference": "string.टेक्स्ट.348",
    "text": "स्पार्स",
  },
  {
    "reference": "string.टेक्स्ट.349",
    "text": "सिस्टम",
  },
  {
    "reference": "string.टेक्स्ट.350",
    "text": "शुरू हो रहा है...",
  },
  {
    "reference": "string.टेक्स्ट.351",
    "text": "समाप्त",
  },
  {
    "reference": "string.टेक्स्ट.352",
    "text": "आर्काइव्ज़ में से फ़ाइल बहार निकाली जा रही है...",
  },
  {
    "reference": "string.टेक्स्ट.353",
    "text": "%s इस मशिन पर वैध पथ नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.354",
    "text": "NEAR ऑपरेटर का अवैध उपयोग। आगे का ऑपरेटर नहीं मिला।",
  },
  {
    "reference": "string.टेक्स्ट.355",
    "text": "फ़ाइल लोकेटर प्रो परिणाम",
  },
  {
    "reference": "string.टेक्स्ट.356",
    "text": "रद्द हो रहा है...",
  },
  {
    "reference": "string.टेक्स्ट.357",
    "text": "कार्य रद्द हो रहा है...",
  },
  {
    "reference": "string.टेक्स्ट.358",
    "text": "चयन की गई फ़ाइलों में से एक या एकाधिक फ़ाइलें कम्पोज़िट फ़ाइलें हैं और ये डील नहीं की जाएंगी। क्या आप जारी रखना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.359",
    "text": "मिटाने का कार्य सफलतापूर्वक संपन्न नहीं। कुछ फ़ाइलें डीलिट नहीं की गई।",
  },
  {
    "reference": "string.टेक्स्ट.360",
    "text": "मेनू विकल्प लागू हो रहा है",
  },
  {
    "reference": "string.टेक्स्ट.361",
    "text": "चेतावनी: प्रोसेस्ड फ़ाइलों में से %d पर ऑपरेशन असफल। अधिक जानकारी के लिए लॉग देखें।",
  },
  {
    "reference": "string.टेक्स्ट.362",
    "text": "फ़ाइल डेटा निकला जा रहा है।",
  },
  {
    "reference": "string.टेक्स्ट.363",
    "text": "ड्रैग-ड्रॉप के लिए सभी आइटम उपलब्ध होने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.364",
    "text": "फ़ाइल डेटा बन रहा है",
  },
  {
    "reference": "string.टेक्स्ट.365",
    "text": "वर्तमान चयन पर ऑपरेशन लागू हो रहा है।",
  },
  {
    "reference": "string.टेक्स्ट.366",
    "text": "चेतावनी: चयन फ़ाइलों में से (%s)ऑपरेशन असफल। अधिक जानकारी के लिए लॉग देखें।",
  },
  {
    "reference": "string.टेक्स्ट.367",
    "text": "डिफॉल्ट",
  },
  {
    "reference": "string.टेक्स्ट.368",
    "text": "कन्टेक्स्ट मेनू लागु हो रहा है",
  },
  {
    "reference": "string.टेक्स्ट.369",
    "text": "पृष्ठ %d of %d",
  },
  {
    "reference": "string.टेक्स्ट.370",
    "text": "... अतिरिक्त पंक्तियां काट दी गयी ...",
  },
  {
    "reference": "string.टेक्स्ट.371",
    "text": "नाम",
  },
  {
    "reference": "string.टेक्स्ट.372",
    "text": "स्थान",
  },
  {
    "reference": "string.टेक्स्ट.373",
    "text": "बदली गई",
  },
  {
    "reference": "string.टेक्स्ट.374",
    "text": "बनाई गई",
  },
  {
    "reference": "string.टेक्स्ट.375",
    "text": "अंतिम बार खोली गई",
  },
  {
    "reference": "string.टेक्स्ट.376",
    "text": "हिट्स",
  },
  {
    "reference": "string.टेक्स्ट.377",
    "text": "अज्ञात",
  },
  {
    "reference": "string.टेक्स्ट.378",
    "text": "CFileListCtrl::loadList() के दौरान असफल।",
  },
  {
    "reference": "string.टेक्स्ट.379",
    "text": "फ़ाइल व्यूअर फ्रेम बन रहा है।",
  },
  {
    "reference": "string.टेक्स्ट.380",
    "text": "खोज स्ट्रिन्ग अवैध है: 
%s",
  },
  {
    "reference": "string.टेक्स्ट.381",
    "text": "संपादक खोलने में असमर्थ। यदि समस्या जारी रहे, तो तकनीकी साहायता से संपर्क करें।",
  },
  {
    "reference": "string.टेक्स्ट.382",
    "text": "फ़ाइल",
  },
  {
    "reference": "string.टेक्स्ट.383",
    "text": "संदेश",
  },
  {
    "reference": "string.टेक्स्ट.384",
    "text": "माप",
  },
  {
    "reference": "string.टेक्स्ट.385",
    "text": "छोटे आइकन",
  },
  {
    "reference": "string.टेक्स्ट.386",
    "text": "मध्यम आइकन",
  },
  {
    "reference": "string.टेक्स्ट.387",
    "text": "बड़े आइकन",
  },
  {
    "reference": "string.टेक्स्ट.388",
    "text": "अत्यंत बड़े आइकन",
  },
  {
    "reference": "string.टेक्स्ट.389",
    "text": "Preview",
  },
  {
    "reference": "string.टेक्स्ट.390",
    "text": "सारांश रिपोर्ट दिखा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.391",
    "text": "क्या आप फ़ाइल लोकेटर प्रो के साथ जुड़ी सभी जानकारी मिटाना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.392",
    "text": "उपयोगकर्ता की जानकारी मिटाएं",
  },
  {
    "reference": "string.टेक्स्ट.393",
    "text": "मिटाना असफल",
  },
  {
    "reference": "string.टेक्स्ट.394",
    "text": "डायलॉग का भाषांतर करने में असमर्थ।",
  },
  {
    "reference": "string.टेक्स्ट.395",
    "text": "क्या आप फेवरेट मिटाना चाहते है? '%s'?",
  },
  {
    "reference": "string.टेक्स्ट.396",
    "text": "%s स्क्रिप्ट अवैध है।

अतिरिक्त जानकारी:

%s",
  },
  {
    "reference": "string.टेक्स्ट.397",
    "text": "क्या आप खोज फिल्टर मिटाना चाहते हैं? '%s'?",
  },
  {
    "reference": "string.टेक्स्ट.398",
    "text": "आइफिल्टर्स",
  },
  {
    "reference": "string.टेक्स्ट.399",
    "text": "नीचे",
  },
  {
    "reference": "string.टेक्स्ट.400.regex",
    "text": "शुरू",
  },
  {
    "reference": "string.टेक्स्ट.401.regex",
    "text": "आज",
  },
  {
    "reference": "string.टेक्स्ट.402.regex",
    "text": "अभी",
  },
  {
    "reference": "string.टेक्स्ट.403.regex",
    "text": "से.*",
  },
  {
    "reference": "string.टेक्स्ट.404.regex",
    "text": "मि.*",
  },
  {
    "reference": "string.टेक्स्ट.405.regex",
    "text": "म.*",
  },
  {
    "reference": "string.टेक्स्ट.406.regex",
    "text": "घं.*",
  },
  {
    "reference": "string.टेक्स्ट.407.regex",
    "text": "द.*",
  },
  {
    "reference": "string.टेक्स्ट.408.regex",
    "text": "ह.*",
  },
  {
    "reference": "string.टेक्स्ट.409.regex",
    "text": "सा.*",
  },
  {
    "reference": "string.टेक्स्ट.410.regex",
    "text": "\b(today)|(start|end) *(?: +(?:the|of|this))* +(w|mo|y)[a-z]*",
  },
  {
    "reference": "string.टेक्स्ट.411.regex",
    "text": "\b(now)|(start|end) *(?: +(?:the|of|this))* +(mi|h|d)[a-z]*",
  },
  {
    "reference": "string.टेक्स्ट.412.regex",
    "text": "([+-]) *([0-9]+) *(d|w|mo|y)[a-z]*",
  },
  {
    "reference": "string.टेक्स्ट.413.regex",
    "text": "([+-]) *([0-9]+) *(s|mi|h)[a-z]*",
  },
  {
    "reference": "string.टेक्स्ट.414.regex",
    "text": "\b[0-9]+(?: *(am|pm)|(?:[:][0-9]+)+) *(am|pm)?\b",
  },
  {
    "reference": "string.टेक्स्ट.415",
    "text": "B",
  },
  {
    "reference": "string.टेक्स्ट.416",
    "text": "KB",
  },
  {
    "reference": "string.टेक्स्ट.417",
    "text": "MB",
  },
  {
    "reference": "string.टेक्स्ट.418",
    "text": "GB",
  },
  {
    "reference": "string.टेक्स्ट.420",
    "text": "AND",
  },
  {
    "reference": "string.टेक्स्ट.421",
    "text": "OR",
  },
  {
    "reference": "string.टेक्स्ट.422",
    "text": "NOT",
  },
  {
