    "text": "LIKE",
  },
  {
    "reference": "string.टेक्स्ट.425",
    "text": "REGEX",
  },
  {
    "reference": "string.टेक्स्ट.426",
    "text": "DOSEX",
  },
  {
    "reference": "string.टेक्स्ट.427",
    "text": "LINES",
  },
  {
    "reference": "string.टेक्स्ट.428",
    "text": "FILELIST",
  },
  {
    "reference": "string.टेक्स्ट.430.regex",
    "text": "AND",
  },
  {
    "reference": "string.टेक्स्ट.431.regex",
    "text": "OR",
  },
  {
    "reference": "string.टेक्स्ट.432.regex",
    "text": "NOT",
  },
  {
    "reference": "string.टेक्स्ट.433.regex",
    "text": "NEAR(:\d+)?",
  },
  {
    "reference": "string.टेक्स्ट.434.regex",
    "text": "LIKE",
  },
  {
    "reference": "string.टेक्स्ट.435.regex",
    "text": "REGEX",
  },
  {
    "reference": "string.टेक्स्ट.436.regex",
    "text": "DOSEX",
  },
  {
    "reference": "string.टेक्स्ट.437.regex",
    "text": "LINES?:([^ ]*)?",
  },
  {
    "reference": "string.टेक्स्ट.438.regex",
    "text": "FILELIST",
  },
  {
    "reference": "string.टेक्स्ट.440",
    "text": "स्थानिकरण",
  },
  {
    "reference": "string.टेक्स्ट.441",
    "text": "नयी खोज शुरू करने के लिए मेमरी अपर्याप्त। कृपया पिछले सत्र तथा अन्य एप्लिकेशन बंद करके प्रयत्न करें।",
  },
  {
    "reference": "string.टेक्स्ट.442",
    "text": "काटा गया (मेमरी खाली करने के लिए)",
  },
  {
    "reference": "string.टेक्स्ट.443",
    "text": "Because regular expressions work slightly differently than Wildcard expressions the result of the Expression Wizard may look different to what you are used to. e.g. The Wildcard expression 'filename.*' as a regular expression is '^filename\.*'.",
  },
  {
    "reference": "string.टेक्स्ट.444",
    "text": "फ़ाइल लोकेटर प्रो फ़ाइल में पंक्ति दर पंक्ति खोज करके प्रत्येक पंक्ति को निश्चित एक्स्प्रेशन के साथ मिलाता है। पंक्ति की शुरूआत कैसे हो, बाद में क्या आयेगा और कैसे अंत होगा, यह एक्स्प्रेशन तय करने देता है। फ़ाइल लोकेटर प्रो उसके बाद फिर उस एक्स्प्रेशन से मिलती सभी पंक्तियों को खोजेगा।",
  },
  {
    "reference": "string.टेक्स्ट.445",
    "text": "फ़ाइलनेम",
  },
  {
    "reference": "string.टेक्स्ट.446",
    "text": "पंक्ति",
  },
  {
    "reference": "string.टेक्स्ट.447",
    "text": "खोलें",
  },
  {
    "reference": "string.टेक्स्ट.448",
    "text": "अटैचमेन्ट्स",
  },
  {
    "reference": "string.टेक्स्ट.449",
    "text": "रोका गया (मेमरी समाप्त)",
  },
  {
    "reference": "string.टेक्स्ट.450",
    "text": "शामिल टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.451",
    "text": "आइटम",
  },
  {
    "reference": "string.टेक्स्ट.452",
    "text": "दिन",
  },
  {
    "reference": "string.टेक्स्ट.453",
    "text": "सप्ताह",
  },
  {
    "reference": "string.टेक्स्ट.454",
    "text": "महीने",
  },
  {
    "reference": "string.टेक्स्ट.455",
    "text": "साल",
  },
  {
    "reference": "string.टेक्स्ट.456",
    "text": "हिट",
  },
  {
    "reference": "string.टेक्स्ट.457",
    "text": "हिट्स",
  },
  {
    "reference": "string.टेक्स्ट.458",
    "text": "टैब विभाजित (स्प्रेडशीट)",
  },
  {
    "reference": "string.टेक्स्ट.459",
    "text": "%s सेटिंग्स",
  },
  {
    "reference": "string.टेक्स्ट.460",
    "text": "यह फ़ाइल लोकेटर प्रो का नविनतम संस्करण है।",
  },
  {
    "reference": "string.टेक्स्ट.461",
    "text": "अपडेट जांचते समय त्रुटि। कृपया अधिक जानकारी के लिए लॉग देखें।",
  },
  {
    "reference": "string.टेक्स्ट.462",
    "text": "वर्कस्पेस सहेजा जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.463",
    "text": "खोज सत्र सहेजा जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.464",
    "text": "वर्कस्पेस फ़ाइलें (*.flwx)|*.flwx",
  },
  {
    "reference": "string.टेक्स्ट.465",
    "text": "फ़ाइल लोकेटर प्रो फ़ाइलें (*.flwx;*.flsx;*.srf)|*.flwx;*.flsx;*.srf",
  },
  {
    "reference": "string.टेक्स्ट.466",
    "text": "खोज क्राइटिरिया (*.srf)|*.srf",
  },
  {
    "reference": "string.टेक्स्ट.467",
    "text": "सभी फ़ाइलें (*.*)|*.*",
  },
  {
    "reference": "string.टेक्स्ट.468",
    "text": "वर्कस्पेस खुल रहा है",
  },
  {
    "reference": "string.टेक्स्ट.469",
    "text": "खोज सत्र खूल रहा है",
  },
  {
    "reference": "string.टेक्स्ट.470",
    "text": "फ़ाइल खोलने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.471",
    "text": "खोज सत्र फ़ाइलें(*.flsx)|*.flsx",
  },
  {
    "reference": "string.टेक्स्ट.472",
    "text": "%s पहले से उपस्थित है। 

क्या आप इसके स्थान पर सहेजना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.473",
    "text": "शुरु करने वाले पैरेन्थिसेस '(' के अनुरूप बंद करने वाला पैरेन्थिसेस  ')' नहीं पाया गया शाब्दिक टेक्स्ट के निर्देश के लिए क्वॉट का उपयोग करें, जैसे, "ending)"",
  },
  {
    "reference": "string.टेक्स्ट.474",
    "text": "बंद करने वाले पैरेन्थिसेस ')' के अनुरूप शुरू करने वाला पैरेन्थिसेस '(' नहीं पाया गया। शाब्दिक टेक्स्ट के निर्देश के लिए क्वॉट का उपयोग करें,  जैसे, "(starting" or "विधि("

त्रुटि स्थान: %d
टेक्स्ट: %s",
  },
  {
    "reference": "string.टेक्स्ट.475",
    "text": "की-वर्ड '%s' कम्पाइल नहीं हो सकता। कृपया की-वर्ड के सही उपयोग के लिए दस्तावेज़ देखें।",
  },
  {
    "reference": "string.टेक्स्ट.476",
    "text": "कैशे लोकेशन बदलने से वर्तमान कैशे मिट जाएगा। क्या आप जारी रखना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.477",
    "text": "कैशे डेटाबेस मिटाने में असमर्थ। कृपया यह जांचें कि एप्लिकेशन का अन्य कोई इन्स्टेन्स चालू न हो, और फिर से प्रयत्न करें।",
  },
  {
    "reference": "string.टेक्स्ट.478",
    "text": "रिपोर्ट",
  },
  {
    "reference": "string.टेक्स्ट.479",
    "text": "टेबल फॉर्मेट में",
  },
  {
    "reference": "string.टेक्स्ट.480",
    "text": "स्टैन्डर्ड",
  },
  {
    "reference": "string.टेक्स्ट.481",
    "text": "फ़ाइल सूची",
  },
  {
    "reference": "string.टेक्स्ट.482",
    "text": "कन्टेन्ट्स",
  },
  {
    "reference": "string.टेक्स्ट.483",
    "text": "की-वर्ड सारांश",
  },
  {
    "reference": "string.टेक्स्ट.484",
    "text": "HTML",
  },
  {
    "reference": "string.टेक्स्ट.485",
    "text": "चयनित  फ़ाइलों के लिए कन्टेक्स्ट मेनू बनाने में विन्डो शेल असमर्थ। क्या आप सीमित कन्टेक्स्ट मेनू के साथ जारी रखना चाहेंगे?",
  },
  {
    "reference": "string.टेक्स्ट.486",
    "text": "प्रश्न",
  },
  {
    "reference": "string.टेक्स्ट.487",
    "text": "त्रुटि",
  },
  {
    "reference": "string.टेक्स्ट.488",
    "text": "जानकारी",
  },
  {
    "reference": "string.टेक्स्ट.489",
    "text": "मेमरी मैनेजर",
  },
  {
    "reference": "string.टेक्स्ट.490",
    "text": "सारांश",
  },
  {
    "reference": "string.टेक्स्ट.491",
    "text": "फ़ाइल से",
  },
  {
    "reference": "string.टेक्स्ट.492",
    "text": "सभी फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.493",
    "text": "केवल चयनित फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.494",
    "text": "सभी",
  },
  {
    "reference": "string.टेक्स्ट.495",
    "text": "चयनित",
  },
  {
    "reference": "string.टेक्स्ट.496",
    "text": "CSV",
  },
  {
    "reference": "string.टेक्स्ट.497",
    "text": "टैब",
  },
  {
    "reference": "string.टेक्स्ट.498",
    "text": "की-वर्ड से फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.499",
    "text": "फ़ाइल एक्स्टेन्शन",
  },
  {
    "reference": "string.टेक्स्ट.500",
    "text": "संख्या",
  },
  {
    "reference": "string.टेक्स्ट.501",
    "text": "की-वर्ड नाम",
  },
  {
    "reference": "string.टेक्स्ट.502",
    "text": "परिणाम",
  },
  {
    "reference": "string.टेक्स्ट.503",
    "text": "छिपा",
  },
  {
    "reference": "string.टेक्स्ट.504",
    "text": "इससे पहले",
  },
  {
    "reference": "string.टेक्स्ट.505",
    "text": "इसके बाद",
  },
  {
    "reference": "string.टेक्स्ट.506",
    "text": "खोज क्राइटिरिया",
  },
  {
    "reference": "string.टेक्स्ट.507",
    "text": "%s रिपोर्ट फ़ाइल कन्टेन्ट्स पर खोज करते समय ही वैध है।",
  },
  {
    "reference": "string.टेक्स्ट.508",
    "text": "की-वर्ड हिट",
  },
  {
    "reference": "string.टेक्स्ट.509",
    "text": "सहेजना असफल। यह जांचें कि आपके पास निर्दिष्ट फ़ाइल एवं फोल्डर में लिखने के लिए उपयुक्त अधिकार है।",
  },
  {
    "reference": "string.टेक्स्ट.510",
    "text": "रिपोर्ट रद्द हो रही है...",
  },
  {
    "reference": "string.टेक्स्ट.511",
    "text": "रिपोर्ट पूर्ण नहीं हुई।",
  },
  {
    "reference": "string.टेक्स्ट.512",
    "text": "रिपोर्ट बनाते समय त्रुटि।",
  },
  {
    "reference": "string.टेक्स्ट.513",
    "text": "रिपोर्ट बन रही है...",
  },
  {
    "reference": "string.टेक्स्ट.514",
    "text": "सिक्वेन्श्यल आईडी",
  },
  {
    "reference": "string.टेक्स्ट.515",
    "text": "Seq Id",
  },
  {
    "reference": "string.टेक्स्ट.516",
    "text": "सिक्वेन्श्यल आईडी (प्रति फ़ाइल)",
  },
  {
    "reference": "string.टेक्स्ट.517",
    "text": "File Seq Id",
  },
  {
    "reference": "string.टेक्स्ट.518",
    "text": "संपूर्ण फ़ाइल पथ",
  },
  {
    "reference": "string.टेक्स्ट.520",
    "text": "केवल फोल्डर",
  },
  {
    "reference": "string.टेक्स्ट.521",
    "text": "केवल फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.522",
    "text": "दस्तावेज़",
  },
  {
    "reference": "string.टेक्स्ट.523",
    "text": "संगीत",
  },
  {
    "reference": "string.टेक्स्ट.524",
    "text": "चित्र",
  },
  {
    "reference": "string.टेक्स्ट.525",
    "text": "वीडीयो",
  },
  {
    "reference": "string.टेक्स्ट.526",
    "text": "टेक्निश्यन लाइसेन्स: %s लाइसेन्स",
  },
  {
    "reference": "string.टेक्स्ट.527",
    "text": "सर्वर लाइसेन्स: %s लाइसेन्स",
  },
  {
    "reference": "string.टेक्स्ट.528",
    "text": "प्राथमिक",
  },
  {
    "reference": "string.टेक्स्ट.529",
    "text": "द्वितीयक",
  },
  {
    "reference": "string.टेक्स्ट.530",
    "text": "पंक्ति सं.",
  },
  {
    "reference": "string.टेक्स्ट.531",
    "text": "पंक्ति संख्या",
  },
  {
    "reference": "string.टेक्स्ट.532",
    "text": "फिल्टर",
  },
  {
    "reference": "string.टेक्स्ट.533",
    "text": "खोज परिणामों पर फिल्टर लगाएं",
  },
  {
    "reference": "string.टेक्स्ट.534",
    "text": "खोज क्राइटिरिया के अनुरूप कोई फ़ाइलें/फोल्डर नहीं मिले",
  },
  {
    "reference": "string.टेक्स्ट.535",
    "text": "कॉलम फिल्टरों के अनुरूप कोई परिणाम नहीं",
  },
  {
    "reference": "string.टेक्स्ट.536",
    "text": "खोज जारी है",
  },
  {
    "reference": "string.टेक्स्ट.537",
    "text": "'%s'एक्स्प्रेशन प्रकार के लिए वैध नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.538",
    "text": "रिपोर्ट की गई त्रुटि",
  },
  {
    "reference": "string.टेक्स्ट.539",
    "text": "टास्क चलाने में समस्या",
  },
  {
    "reference": "string.टेक्स्ट.540",
    "text": "त्रुटि हुई है। यदि समस्या जारी रहे, तो तकनीकी सहायता से संपर्क करें।",
  },
  {
    "reference": "string.टेक्स्ट.541",
    "text": "अतिरिक्त जानकारी",
  },
  {
    "reference": "string.टेक्स्ट.542",
    "text": "शीर्षक",
  },
  {
    "reference": "string.टेक्स्ट.543",
    "text": "कलाकार",
  },
  {
    "reference": "string.टेक्स्ट.544",
    "text": "एल्बम",
  },
  {
    "reference": "string.टेक्स्ट.545",
    "text": "टिप्पणी",
  },
  {
    "reference": "string.टेक्स्ट.546",
    "text": "ज़ॉनर",
  },
  {
    "reference": "string.टेक्स्ट.547",
    "text": "साल",
  },
  {
    "reference": "string.टेक्स्ट.548",
    "text": "ट्रैक",
  },
  {
    "reference": "string.टेक्स्ट.549",
    "text": "लंबाई: %s सेकन्ड",
  },
  {
    "reference": "string.टेक्स्ट.550",
    "text": "बिट रेट: %s Kbps",
  },
  {
    "reference": "string.टेक्स्ट.551",
    "text": "सैम्पल रेट: %s Hz",
  },
  {
    "reference": "string.टेक्स्ट.552",
    "text": "चैनल्स: %s",
  },
  {
    "reference": "string.टेक्स्ट.553",
    "text": "चौड़ाई",
  },
  {
    "reference": "string.टेक्स्ट.554",
    "text": "ऊंचाई",
  },
  {
    "reference": "string.टेक्स्ट.555",
    "text": "सेम्पल्स",
  },
  {
    "reference": "string.टेक्स्ट.556",
    "text": "दस्तावेज़",
  },
  {
