    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.caption",
    "text": "",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.1",
    "text": "नाम:",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.2",
    "text": "<name>",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.3",
    "text": "फ़ाइल के प्रकार:",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.4",
    "text": "(प्रत्येक वैध फ़ाइल प्रकार को अलग पंक्ति में जोडें।)",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.5",
    "text": "प्रोग्राम आईडी:",
  },
  {
    "reference": "dialog.IDD_CONFIGENTRY_EXTENSION.6",
