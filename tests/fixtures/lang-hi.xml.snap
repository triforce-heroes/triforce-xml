  },
  {
    "reference": "string.टेक्स्ट.577",
    "text": "क्रीएटिव",
  },
  {
    "reference": "string.टेक्स्ट.578",
    "text": "एक्शन",
  },
  {
    "reference": "string.टेक्स्ट.579",
    "text": "पोर्ट्रैट",
  },
  {
    "reference": "string.टेक्स्ट.580",
    "text": "लेन्ड्स्केप",
  },
  {
    "reference": "string.टेक्स्ट.581",
    "text": "ISO गति",
  },
  {
    "reference": "string.टेक्स्ट.582",
    "text": "मूल तारीख़़",
  },
  {
    "reference": "string.टेक्स्ट.583",
    "text": "फ्लैश",
  },
  {
    "reference": "string.टेक्स्ट.584",
    "text": "टिप्पणी",
  },
  {
    "reference": "string.टेक्स्ट.585",
    "text": "माप",
  },
  {
    "reference": "string.टेक्स्ट.586",
    "text": "प्रति पिक्सेल बिट",
  },
  {
    "reference": "string.टेक्स्ट.587",
    "text": "आल्फा चैनल",
  },
  {
    "reference": "string.टेक्स्ट.588",
    "text": "केवल फोल्डर खोज को सिर्फ फोल्डरों तक सीमित कर देता है, यानि, फ़ाइलें नहीं दिखाई जाएंगी।",
  },
  {
    "reference": "string.टेक्स्ट.589",
    "text": "केवल फ़ाइलें खोज को सिर्फ़ फ़ाइलों तक सीमित कर देता है, यानि, कोई भी फोल्डर नहीं दिखाया जाएगा।",
  },
  {
    "reference": "string.टेक्स्ट.590",
    "text": "दस्तावेज़ खोज को केवल स्टैन्डर्ड दस्तावेज़ एक्सटेन्शनों वाली फ़ाइलों तक सीमित कर देता है।",
  },
  {
    "reference": "string.टेक्स्ट.591",
    "text": "संगीत खोज को केवल स्टैन्डर्ड ऑडियो फ़ाइल एक्सटेन्शनों वाली फ़ाइलों तक सीमित कर देता है।",
  },
  {
    "reference": "string.टेक्स्ट.592",
    "text": "चित्र खोज को केवल स्टैन्डर्ड इमेज फ़ाइल एक्सटेन्शनों वाली फ़ाइलों तक सीमित कर देता है।",
  },
  {
    "reference": "string.टेक्स्ट.593",
    "text": "वीडियो खोज को केवल स्टैन्डर्ड वीडियो फ़ाइल एक्सटेन्शनों वाली फ़ाइलों तक सीमित कर देता है।",
  },
  {
    "reference": "string.टेक्स्ट.600",
    "text": "लंबित खोज",
  },
  {
    "reference": "string.टेक्स्ट.601",
    "text": "त्रुटि - खोज शुरू नहीं किया जा सका",
  },
  {
    "reference": "string.टेक्स्ट.602",
    "text": "काटें नहीं",
  },
  {
    "reference": "string.टेक्स्ट.603",
    "text": "बीच का काटें",
  },
  {
    "reference": "string.टेक्स्ट.604",
    "text": "शुरू का काटें",
  },
  {
    "reference": "string.टेक्स्ट.605",
    "text": "अंत का काटें",
  },
  {
    "reference": "string.टेक्स्ट.606",
    "text": "प्राप्त आइटमों को किसी अन्य स्थान या ज़िप फ़ाइल में कॉपी करें ",
  },
  {
    "reference": "string.टेक्स्ट.607",
    "text": "वर्तमान खोज सत्र या पूरे वर्कस्पेस को एक फ़ाइल में सहेजें जिसे फिर फ़ाइल लोकेटर प्रो में खोज परिणामों को लोड करने के लिए उपयोग किया जा सकता है।",
  },
  {
    "reference": "string.टेक्स्ट.608",
    "text": "खोज परिणामों को एक बाह्य फॉर्मेट जैसे, Text, CSV, HTML, XML आदि में एक्स्पोर्ट करें",
  },
  {
    "reference": "string.टेक्स्ट.609",
    "text": "कॉपी करना शुरू करें",
  },
  {
    "reference": "string.टेक्स्ट.610",
    "text": "एक्स्पोर्ट करें",
  },
  {
    "reference": "string.टेक्स्ट.611",
    "text": "फ्लैट",
  },
  {
    "reference": "string.टेक्स्ट.612",
    "text": "रूट से",
  },
  {
    "reference": "string.टेक्स्ट.613",
    "text": "पहले कॉमन फॉल्डर से",
  },
  {
    "reference": "string.टेक्स्ट.614",
    "text": "ओवरराइट करें",
  },
  {
    "reference": "string.टेक्स्ट.615",
    "text": "सिक्वेन्स संख्या से जोड़ें",
  },
  {
    "reference": "string.टेक्स्ट.616",
    "text": "फ़ाइल कॉपी न करें",
  },
  {
    "reference": "string.टेक्स्ट.617",
    "text": "केवल एकल प्राप्त आइटमों को कॉपी करें",
  },
  {
    "reference": "string.टेक्स्ट.618",
    "text": "मुख्य  फ़ाइल कॉपी करें",
  },
  {
    "reference": "string.टेक्स्ट.619",
    "text": "डुपलिकेट कॉपी करें",
  },
  {
    "reference": "string.टेक्स्ट.620",
    "text": "मूल के लिए शॉर्ट-कट बनाएं",
  },
  {
    "reference": "string.टेक्स्ट.621",
    "text": "त्रुटि लॉग करें",
  },
  {
    "reference": "string.टेक्स्ट.622",
    "text": "रोकें",
  },
  {
    "reference": "string.टेक्स्ट.623",
    "text": "एक्शन के लिए प्रॉम्प्ट करें",
  },
  {
    "reference": "string.टेक्स्ट.624",
    "text": "फ़ाइल बनाने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.625",
    "text": "कॉपी किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.626",
    "text": "असफल फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.627",
    "text": "कॉपी असफल रहा",
  },
  {
    "reference": "string.टेक्स्ट.628",
    "text": "फ़ाइलों को सफलतापूर्वक कॉपी कर दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.629",
    "text": "कॉपी रद्द कर दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.630",
    "text": "स्थान",
  },
  {
    "reference": "string.टेक्स्ट.631",
    "text": "संपादित करने के लिए डबल-क्लिक करें",
  },
  {
    "reference": "string.टेक्स्ट.632",
    "text": "टेक्स्ट फ़ाइलें (*.txt)|*.txt|सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.633",
    "text": "वर्तमान फ़ाइल को ओवरराइट करें?",
  },
  {
    "reference": "string.टेक्स्ट.634",
    "text": "स्क्रिप्टिंग",
  },
  {
    "reference": "string.टेक्स्ट.635",
    "text": "खोज क्राइटिरिया ने सूची से %s आइटम शामिल नहीं किए",
  },
  {
    "reference": "string.टेक्स्ट.636",
    "text": "शामिल न की गई फ़ाइलें",
  },
  {
    "reference": "string.टेक्स्ट.637",
    "text": "अवैध स्थान",
  },
  {
    "reference": "string.टेक्स्ट.638",
    "text": "रिपोर्ट की गई त्रुटियाँ",
  },
  {
    "reference": "string.टेक्स्ट.639",
    "text": "सब-फोल्डर खोज ऑफ़ है",
  },
  {
    "reference": "string.टेक्स्ट.640",
    "text": "शामिल टेक्स्ट फील्ड में केवल वाइटस्पेस कैरेक्टर उपस्थित हैं",
  },
  {
    "reference": "string.टेक्स्ट.641",
    "text": "चेतावनी",
  },
  {
    "reference": "string.टेक्स्ट.642",
    "text": "खोज के दौरान उत्पन्न चेतावनियाँ",
  },
  {
    "reference": "string.टेक्स्ट.643",
    "text": "ज़िप फ़ाइलें (*.zip)|*.zip|सभी फ़ाइलें (*.*)|*.*||",
  },
  {
    "reference": "string.टेक्स्ट.644",
    "text": "फ़ाइलनाम मैच केस ऑन है",
  },
  {
    "reference": "string.टेक्स्ट.645",
    "text": "शामिल टेक्स्ट मैच केस ऑन है",
  },
  {
    "reference": "string.टेक्स्ट.646",
    "text": "संदेश का हिस्सा",
  },
  {
    "reference": "string.टेक्स्ट.647",
    "text": "ईमेल",
  },
  {
    "reference": "string.टेक्स्ट.648",
    "text": "पृष्ठ",
  },
  {
    "reference": "string.टेक्स्ट.649",
    "text": "बल्क कॉपी रिपोर्ट",
  },
  {
    "reference": "string.टेक्स्ट.650",
    "text": "फ़ाइल सहेजी जा रही है",
  },
  {
    "reference": "string.टेक्स्ट.651",
    "text": "फ्लोटिंग लाइसेन्स:  %s तक साथ-साथ इस्तेमाल करने वाले यूज़र",
  },
  {
    "reference": "string.टेक्स्ट.652",
    "text": "%s फाइल(लें) खोजी नहीं जा सकीं",
  },
  {
    "reference": "string.टेक्स्ट.653",
    "text": "विवरण के लिए क्लिक करें",
  },
  {
    "reference": "string.टेक्स्ट.654",
    "text": "गंभीरता",
  },
  {
    "reference": "string.टेक्स्ट.655",
    "text": "विवरण",
  },
  {
    "reference": "string.टेक्स्ट.656",
    "text": "पाथ का आरंभ दिखाएं",
  },
  {
    "reference": "string.टेक्स्ट.657",
    "text": "पाथ का अंत दिखाएं",
  },
  {
    "reference": "string.टेक्स्ट.658",
    "text": "%s फ़ाइल(लों) ने खोज चेतावनियाँ रिपोर्ट की",
  },
  {
    "reference": "string.टेक्स्ट.659",
    "text": "फ़ाइलनाम प्रीसेट उपयोग करते हुए",
  },
  {
    "reference": "string.टेक्स्ट.660",
    "text": "GPS डाटा",
  },
  {
    "reference": "string.टेक्स्ट.661",
    "text": "साइट लाइसेन्स। अधिकतम यूज़र: %s",
  },
  {
    "reference": "string.टेक्स्ट.662",
    "text": "निकाला जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.663",
    "text": "डेस्टिनेशन",
  },
  {
    "reference": "string.टेक्स्ट.664",
    "text": "कॉपी नहीं किया गया - डेस्टिनेशन में फ़ाइलें पहले से ही उपस्थित हैं",
  },
  {
    "reference": "string.टेक्स्ट.665",
    "text": "बल्क कॉपी",
  },
  {
    "reference": "string.टेक्स्ट.666",
    "text": "खोज परिणाम एक्स्पोर्ट किए जा रहे हैं",
  },
  {
    "reference": "string.टेक्स्ट.700",
    "text": "बहु-पंक्ति RegEx",
  },
  {
    "reference": "string.टेक्स्ट.701",
    "text": "निपुण",
  },
  {
    "reference": "string.टेक्स्ट.702",
    "text": "बेसिक",
  },
  {
    "reference": "string.टेक्स्ट.703",
    "text": "सूचकांक खोज",
  },
  {
    "reference": "string.टेक्स्ट.704",
    "text": "<नया सूचकांक बनाएं...>",
  },
  {
    "reference": "string.टेक्स्ट.705",
    "text": "कोई भी सूचकांक चुना नहीं गया है। कृपया एक सूचकांक चुनें और फिर प्रयास करें।",
  },
  {
    "reference": "string.टेक्स्ट.706",
    "text": "अवैध सूचकांक",
  },
  {
    "reference": "string.टेक्स्ट.707",
    "text": "नया सूचकांक",
  },
  {
    "reference": "string.टेक्स्ट.708",
    "text": "फोल्डर नाम को सूचकांक नाम के साथ सिंक्रनाइज़ किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.709",
    "text": "समय",
  },
  {
    "reference": "string.टेक्स्ट.710",
    "text": "विश्लेषण किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.711",
    "text": "Indexed: %s | Name only: %s | Errors: %s | Invalid: %s | Removed: %s | Unchanged: %s",
  },
  {
    "reference": "string.टेक्स्ट.712",
    "text": "सूचकांक प्रक्रिया को शुरू किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.713",
    "text": "सूचकांक विवरण",
  },
  {
    "reference": "string.टेक्स्ट.714",
    "text": "सूचकांक सूची",
  },
  {
    "reference": "string.टेक्स्ट.715",
    "text": "सूचकांक",
  },
  {
    "reference": "string.टेक्स्ट.716",
    "text": "सूचकांकित कर दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.717",
    "text": "क्या आप सही में इसे डीलिट करना चाहते हैं: %s?",
  },
  {
    "reference": "string.टेक्स्ट.718",
    "text": "सूचकांक को क्लीन किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.719",
    "text": "ऑप्टिमाइज़ किया जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.720",
    "text": "सहेजा जा रहा है",
  },
  {
    "reference": "string.टेक्स्ट.721",
    "text": "...",
  },
  {
    "reference": "string.टेक्स्ट.722",
    "text": "सूचकांक को लोड करने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.723",
    "text": "रद्द कर दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.724",
    "text": "सामान्य दस्तावेज़ स्थान",
  },
  {
    "reference": "string.टेक्स्ट.725",
    "text": "फ़ाइल प्रकार",
  },
  {
    "reference": "string.टेक्स्ट.726",
    "text": "Index size: %s | Indexed count: %s | Name only: %s | Total: %s",
  },
  {
    "reference": "string.टेक्स्ट.727",
    "text": "सूचकांक प्रबंधक",
  },
  {
    "reference": "string.टेक्स्ट.728",
    "text": "सूचकांक फिलहाल अपडेट किए जा रहे हैं। क्या आप सभी सूचकांक प्रक्रियाओं को रद्द करना चाहते हैं ?",
  },
  {
    "reference": "string.टेक्स्ट.729",
    "text": "सूचकांक बनाने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.730",
    "text": "बाइनरी फ़ाइल को छोड़ दिया गया है",
  },
  {
    "reference": "string.टेक्स्ट.731",
    "text": "सूचकांक रीड-ओनली मोड में है",
  },
  {
    "reference": "string.टेक्स्ट.732",
    "text": "फ़ाइल को खोजने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.733",
    "text": "प्राथमिक खोज विधि असफल, रॉ डेटा खोज का उपयोग किया गया।",
  },
  {
    "reference": "string.टेक्स्ट.734",
    "text": "खोज शब्द फ़ाइल सूची एक्सप्रेशन की तरह प्रतीत होता है, लोकिन कन्फिगरेशन विकल्प ऑफ़ है।",
  },
  {
    "reference": "string.टेक्स्ट.735",
    "text": "फ़ाइलनाम फ़ाइल सूची एक्सप्रेशन की तरह प्रतीत होता है, लोकिन कन्फिगरेशन विकल्प ऑफ़ है।",
  },
  {
    "reference": "string.टेक्स्ट.736",
    "text": "जैसा कि विकल्प टैब में निर्दिष्ट किया गया था, खोज एक्सप्रेशन को पंक्ति-दर-पंक्ति के आधार पर जाँचा गया था।",
  },
  {
    "reference": "string.टेक्स्ट.737",
    "text": "आसपास की पंक्तियां",
  },
  {
    "reference": "string.टेक्स्ट.738",
    "text": "आसपास की पंक्तियों के मार्कर",
  },
  {
    "reference": "string.टेक्स्ट.739",
    "text": "हिट लाइनें",
  },
  {
    "reference": "string.टेक्स्ट.740",
    "text": "Commas used in Wildcard expression, was semi-colon intended?",
  },
  {
    "reference": "string.टेक्स्ट.741",
    "text": "रिपार्स बिंदु",
  },
  {
    "reference": "string.टेक्स्ट.742",
    "text": "अपडेट की आवश्यकता - सूचकांक सेटिंग्स को मैच नहीं करता है",
  },
  {
    "reference": "string.टेक्स्ट.743",
    "text": "सूचकांक केस सेन्सेटिव खोजों का समर्थन नहीं करता है। इस विकल्प को सक्षम करने के लिए आपको सूचकांक को केस सेन्सेटिव खोज सक्षम करके दोबारा  बनाना होगा।",
  },
  {
    "reference": "string.टेक्स्ट.744",
    "text": "खोज शुरू नहीं किया जा सका",
  },
  {
    "reference": "string.टेक्स्ट.745",
    "text": "मैच केस ऑन है",
  },
  {
    "reference": "string.टेक्स्ट.746",
    "text": "सूचकांक पुराना हो गया है, खोज को पुराने सूचकांक सेटिंग्स का उपयोग करके चलाया गया है",
  },
  {
    "reference": "string.टेक्स्ट.747",
    "text": "फ़ाइल के लिए हिट्स डिस्प्ले करने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.748",
    "text": "खोज को पूरा होने से पहले रोक दिया गया",
  },
  {
    "reference": "string.टेक्स्ट.749",
    "text": "सूचकांक खाली है",
  },
  {
    "reference": "string.टेक्स्ट.750",
    "text": "कभी नहीं",
  },
  {
    "reference": "string.टेक्स्ट.751",
    "text": "सूचकांक खाली है, सूचकांक प्रबंधक का उपयोग करके सूचकांक बनाएं",
  },
  {
    "reference": "string.टेक्स्ट.752",
    "text": "बाइनरी फ़ाइलों को शामिल नहीं किया गया",
  },
  {
    "reference": "string.टेक्स्ट.753",
    "text": "यूनिक कीवर्ड",
  },
  {
    "reference": "string.टेक्स्ट.754",
    "text": "अवैध तिथि। सिस्टम फ़ाइल 1601 से पहले की नहीं हो सकती है।",
  },
  {
    "reference": "string.टेक्स्ट.755",
    "text": "फ़ाइल को केवल आंशिक रूप से खोजा गया क्योंकि प्राप्त पंक्तियों की संख्या निर्दिष्ट अधिकतम से ज़्यादा थीं।",
  },
  {
    "reference": "string.टेक्स्ट.756",
    "text": "Processing FILELIST operator generated an error",
  },
  {
    "reference": "string.टेक्स्ट.757",
    "text": "रंग",
  },
  {
    "reference": "string.टेक्स्ट.758",
    "text": "अन्य...",
  },
  {
    "reference": "string.टेक्स्ट.759",
    "text": "थ्रेड खोजें",
  },
  {
    "reference": "string.टेक्स्ट.760",
    "text": "एक्शन की पुष्टि करें",
  },
  {
    "reference": "string.टेक्स्ट.761",
    "text": "इस संदेश को दोबारा न दिखाएं",
  },
  {
    "reference": "string.टेक्स्ट.762",
    "text": "चेतावनी: बड़ी फ़ाइल",
  },
  {
    "reference": "string.टेक्स्ट.763",
    "text": "चुनी गई फ़ाइल बहुत बड़ी है और इसे खोलने से प्रोग्रम धीमा हो सकता है या रिस्पॉन्ड करना बंद कर सकता है। ",
  },
  {
    "reference": "string.टेक्स्ट.764",
    "text": "** फ़ाइल की लोडिंग रद्द हो गई है**",
  },
  {
    "reference": "string.टेक्स्ट.765",
    "text": "विवरण दिखाएंl >>",
  },
  {
    "reference": "string.टेक्स्ट.766",
    "text": "<< विवरण छिपाएं",
  },
  {
    "reference": "string.टेक्स्ट.767",
    "text": "इस सुविधा को काम करने के लिए फ़ाइललोकेटर प्रो को इन्टरनेट एक्सप्लोरर में तीसरे पक्ष के ब्राउज़र एक्सटेन्शनों को सक्षम करना होगा और इसे प्रभावी करने के लिए आपको रीबूट करना होगा।

क्या आप जारी रखना चाहेंगे?",
  },
  {
    "reference": "string.टेक्स्ट.768",
    "text": "कोई भी सूचकांक निर्दिष्ट नहीं किया गया है",
  },
  {
    "reference": "string.टेक्स्ट.769",
    "text": "कोई भी सूचकांक ऑपेरशन निर्दिष्ट नहीं किया गया है ",
  },
  {
    "reference": "string.टेक्स्ट.770",
    "text": "अवधि (सेकंड)",
  },
  {
    "reference": "string.टेक्स्ट.771",
    "text": "थ्रेड खोजें",
  },
  {
    "reference": "string.टेक्स्ट.772",
    "text": "रद्द करें",
  },
  {
    "reference": "string.टेक्स्ट.773",
    "text": "इस खोज के लिए फिलहाल कोई भी सामग्री खोज थ्रेड कार्यरत नहीं है",
  },
  {
    "reference": "string.टेक्स्ट.774",
    "text": "इन्डेक्स करने के लिए कृपया स्थान निर्दिष्ट करें",
  },
  {
    "reference": "string.टेक्स्ट.775",
    "text": "कृपया निर्दिष्ट करें कि कौन-सी सामग्री सूचकांक में शामिल की जानी चाहिए ",
  },
  {
    "reference": "string.टेक्स्ट.776",
    "text": "सूचकांक किसी दूसरे एप्लिकेशन द्वारा अद्यतन के लिए लॉक किया गया है",
  },
  {
    "reference": "string.टेक्स्ट.777",
    "text": "समाप्त करने के लिए 'quit' टाइप करें।",
  },
  {
    "reference": "string.टेक्स्ट.778",
    "text": "सूचकांक प्रबंधक प्रारंभ करने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.779",
    "text": "आंशिक खोज परिणाम पूरे किए जा रहे हैं...",
  },
  {
    "reference": "string.टेक्स्ट.780",
    "text": "फझी सर्च",
  },
  {
    "reference": "string.टेक्स्ट.781",
    "text": "स्थान सूचकांक डेटाबेस में स्टोर करने के लिए चुना है एक नया या खाली फ़ोल्डर में होना चाहिए।",
  },
  {
    "reference": "string.टेक्स्ट.782",
    "text": "वर्तमान ओपरेशन में समस्या। सामान्य प्रकार से यह समस्या इन्टरअफेस सेटिंग में 'Individual taskbar tab previews' के कारण होती है। यदि यह समस्या जारी रहे तो इस ओप्शन को बंध करें।",
  },
  {
    "reference": "string.टेक्स्ट.783",
    "text": "सूचकांक बहलाना",
  },
  {
    "reference": "string.टेक्स्ट.784",
    "text": "अद्यतन सूचकांक",
  },
  {
    "reference": "string.टेक्स्ट.785",
    "text": "नए सूचकांक बनाएं",
  },
  {
    "reference": "string.टेक्स्ट.786",
    "text": "नहीं सूचकांक नाम निर्दिष्ट किया गया है।",
  },
  {
    "reference": "string.टेक्स्ट.787",
    "text": "नहीं सूचकांक पथ निर्दिष्ट किया गया है।",
  },
  {
    "reference": "string.टेक्स्ट.788",
    "text": "खोज के दरम्यान  मानदंड बदलने से खोज बंद हो जाएगी। क्या आप यह करना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.789",
    "text": "इन्डेक्सिंग",
  },
  {
    "reference": "string.टेक्स्ट.790",
    "text": "कार्यरत अपवाद या फिल्टर के कारण यह पाथ खोज में सामेल नहीं किया गया था।",
  },
  {
    "reference": "string.टेक्स्ट.791",
    "text": "खाली फाईल, खोज के लायक कोई टेक्स्ट नहीं है",
  },
  {
    "reference": "string.टेक्स्ट.792",
    "text": "अलग-अलग शब्दों में अभिव्यक्ति को अलग करने में असमर्थ",
  },
  {
    "reference": "string.टेक्स्ट.793",
    "text": "खाली फ़ाइल सूची निर्दिष्ट",
  },
  {
    "reference": "string.टेक्स्ट.794",
    "text": "अभिव्यक्ति प्रकार बूलियन में बदल गया था एकाधिक खोज शब्दों का समर्थन है।",
  },
  {
    "reference": "string.टेक्स्ट.795",
    "text": "बड़े अभिव्यक्ति",
  },
  {
    "reference": "string.टेक्स्ट.796",
    "text": "इंडेक्सिंग कार्रवाई विफल रही।",
  },
  {
    "reference": "string.टेक्स्ट.797",
    "text": "इंडेक्स स्टोर",
  },
  {
    "reference": "string.टेक्स्ट.798",
    "text": "कंटेन्ट क्लास",
  },
  {
    "reference": "string.टेक्स्ट.799",
    "text": "क्या आप चूनी हुई ची हमेश अके लिए मीटाना चाहते हैं?",
  },
  {
    "reference": "string.टेक्स्ट.800",
    "text": "चीजे मीट रही हैं",
  },
  {
    "reference": "string.टेक्स्ट.801",
    "text": "एक या एकाधिक लंबी पंक्तियां छोटी पंक्तिओ में विभाजित कि गई है, जो कि सर्च हिट पर असर कर सकती है।",
  },
  {
    "reference": "string.टेक्स्ट.802",
    "text": "नाम-बदल निष्फल। कृपयां फाईल लोक नहीं है यह निश्चित करें।",
  },
  {
    "reference": "string.टेक्स्ट.803",
    "text": "इन्डेक्स लिस्ट लोड हो रहा है",
  },
  {
    "reference": "string.टेक्स्ट.804",
    "text": "वर्तमान इन्डेक्स से संबंध जोडें",
  },
  {
    "reference": "string.टेक्स्ट.805",
    "text": "लेखक",
  },
  {
    "reference": "string.टेक्स्ट.806",
    "text": "दस्तावेज कीवर्ड",
  },
  {
    "reference": "string.टेक्स्ट.807",
    "text": "टिप्पणी",
  },
  {
    "reference": "string.टेक्स्ट.808",
    "text": "शीर्षक",
  },
  {
    "reference": "string.टेक्स्ट.809",
    "text": "मालीक",
  },
  {
    "reference": "string.टेक्स्ट.810",
    "text": "इन्डेक्स पाथ तथा नाम का मेल नहीं।",
  },
  {
    "reference": "string.टेक्स्ट.811",
    "text": "इन्डेक्स मीटाएं",
  },
  {
    "reference": "string.टेक्स्ट.812",
    "text": "List indexes",
  },
  {
    "reference": "string.टेक्स्ट.813",
    "text": "पिछली बार द्वारा सहेजा गया",
  },
  {
    "reference": "string.टेक्स्ट.814",
    "text": "इंडेक्स हटाएं",
  },
  {
    "reference": "string.टेक्स्ट.820",
    "text": "झीरो हीट कीवर्ड",
  },
  {
    "reference": "string.टेक्स्ट.821",
    "text": "%s कीवर्ड मात्र व्यावसायिक संस्करण में ही उपलब्ध है। यदी आप मात्र "%s" शब्दों के लिए ही खो ज रहे हैं, तो कृपयां उन्हें अवतरण-चिह्न लगाएं।",
  },
  {
    "reference": "string.टेक्स्ट.822",
    "text": "मार्यादित अवधी का अधिकार पत्र। दिन बाकीः",
  },
  {
    "reference": "string.टेक्स्ट.823",
    "text": "डायरेक्ट एक्सेस",
  },
  {
    "reference": "string.टेक्स्ट.824",
    "text": "भाषांतरित टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.825",
    "text": "परिवर्तित टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.826",
    "text": "IFilter टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.827",
    "text": "केच्ड टेक्स्ट",
  },
  {
    "reference": "string.टेक्स्ट.828",
    "text": "टेक्स्ट फाईल",
  },
  {
    "reference": "string.टेक्स्ट.829",
    "text": "रॉ फाईल डेटा",
  },
  {
    "reference": "string.टेक्स्ट.830",
    "text": "कंटेन्ट रीडर",
  },
  {
    "reference": "string.टेक्स्ट.831",
    "text": "प्रथम उपयोग के लिए तैयार हो रहा है...",
  },
  {
    "reference": "string.टेक्स्ट.832",
    "text": "आजमाईश अवधी समाप्त।",
  },
  {
    "reference": "string.टेक्स्ट.833",
    "text": "यह विशेषता निशुल्क संस्करण में उपलब्ध नहीं है।",
  },
  {
    "reference": "string.टेक्स्ट.834",
    "text": "व्यावसायिक - आजमाईश",
  },
  {
    "reference": "string.टेक्स्ट.835",
    "text": "व्यावसायिक",
  },
  {
    "reference": "string.टेक्स्ट.836",
    "text": "लाईट",
  },
  {
    "reference": "string.टेक्स्ट.837",
    "text": "व्यावसायिक और व्यक्तिगत दोनों उपयोग के लिए निशुल्क। कुछ विशेषताएं प्रछन्न या निर्योग्य।",
  },
  {
    "reference": "string.टेक्स्ट.838",
    "text": "संपूर्ण कार्यरत संस्करण।",
  },
  {
    "reference": "string.टेक्स्ट.839",
    "text": "आजमाईश के लिए संपूर्ण कार्यरत संस्करण।",
  },
  {
    "reference": "string.टेक्स्ट.840",
    "text": "पंजीकृत नहीं है! 
यह संस्करण मात्र घर में व्यक्तिगत उपयोग के लिए है। 

व्यावसायिक उपयोगकर्ता:

व्यावसायिक कार्य में उपयोग के लिए पंजीकृत कराना आवश्यक है। अन्यथा उपभोक्ता करार की शर्तों व परिस्थितिओं का आप भंग कर रहें हैं।

निशुल्क पंजीकरण संकेत के लिए कृपयां यहां जाएं:
https://www.mythicsoft.com/agentransack/register",
  },
  {
    "reference": "string.टेक्स्ट.841",
    "text": "पंजीकृत नहीं है। 
आजमाईशी अवधी समाप्त हो जाने के पश्चात व्यावसायिक उपयोग के लिए पंजीकरण आवश्यक है।

निशुल्क पंजीकरण संकेत के लिए यहां जाएं:
https://www.mythicsoft.com/agentransack/register",
  },
  {
    "reference": "string.टेक्स्ट.842",
    "text": "कृपयां आपके उपयोग के बारे में बताएं।",
  },
  {
    "reference": "string.टेक्स्ट.843",
    "text": "दोबारा शुरु करने पर बदलाव अमल में।",
  },
  {
    "reference": "string.टेक्स्ट.844",
    "text": "यह पंजीकरण संकेत लाईट संस्करण के लिए है। कुछ विशेषताएं अब निर्योग्य रहेंगी।",
  },
  {
    "reference": "string.टेक्स्ट.845",
    "text": "निशुल्क संस्करण में यह विशेषता उपलब्ध नहीं है।: %s",
  },
  {
    "reference": "string.टेक्स्ट.846",
    "text": "सबसे तेज",
  },
  {
    "reference": "string.टेक्स्ट.847",
    "text": "मध्यम",
  },
  {
    "reference": "string.टेक्स्ट.848",
    "text": "तदनुकूल",
  },
  {
    "reference": "string.टेक्स्ट.849",
    "text": "पाथ की खोज नहीं हो सकती",
  },
  {
    "reference": "string.टेक्स्ट.899",
    "text": "Exclude MS Office Temporary Files",
