    "reference": "string.Tekst.584",
    "text": "Komentarz",
  },
  {
    "reference": "string.Tekst.585",
    "text": "Rozmiar",
  },
  {
    "reference": "string.Tekst.586",
    "text": "Głębia koloru",
  },
  {
    "reference": "string.Tekst.587",
    "text": "Kanał alfa",
  },
  {
    "reference": "string.Tekst.588",
    "text": ""Tylko foldery" ograniczają wyszukiwanie tylko do folderów, tj. żadne pliki nie zostaną zwrócone.",
  },
  {
    "reference": "string.Tekst.589",
    "text": ""Tylko pliki" ogranicza wyszukiwanie tylko do plików, tj. żadne foldery nie zostaną zwrócone.",
  },
  {
    "reference": "string.Tekst.590",
    "text": ""Dokumenty" ogranicza wyszukiwanie tylko do plików ze standardowymi rozszerzeniami dokumentów.",
  },
  {
    "reference": "string.Tekst.591",
    "text": ""Muzyka" ogranicza wyszukiwanie tylko plików ze standardowymi rozszerzeniami plików audio.",
  },
  {
    "reference": "string.Tekst.592",
    "text": ""Obrazy" ogranicza wyszukiwanie tylko do plików ze standardowymi rozszerzeniami plików graficznych.",
  },
  {
    "reference": "string.Tekst.593",
    "text": ""Wideo" ogranicza wyszukiwanie tylko do plików ze standardowymi rozszerzeniami plików filmowych.",
  },
  {
    "reference": "string.Tekst.600",
    "text": "Wyszukiwanie oczekujące",
  },
  {
    "reference": "string.Tekst.601",
    "text": "Błąd - wyszukiwanie nie mogło zostać uruchomione",
  },
  {
    "reference": "string.Tekst.602",
    "text": "Nie skracaj",
  },
  {
    "reference": "string.Tekst.603",
    "text": "Skróć środek",
  },
  {
    "reference": "string.Tekst.604",
    "text": "Skróć początek",
  },
  {
    "reference": "string.Tekst.605",
    "text": "Skróć koniec",
  },
  {
    "reference": "string.Tekst.606",
    "text": "Kopiuje znalezione elementy do innej lokalizacji lub pliku zip.",
  },
  {
    "reference": "string.Tekst.607",
    "text": "Zapisuje bieżącą sesję wyszukiwania lub cały obszar roboczy do pliku, który następnie może zostać użyty do ponownego wczytania wyników wyszukiwania w %APP_NAME%.",
  },
  {
    "reference": "string.Tekst.608",
    "text": "Eksportuje wyniki wyszukiwania do zewnętrznego formatu, takiego jak Tekst, CSV, HTML, XML itp.",
  },
  {
    "reference": "string.Tekst.609",
    "text": "Kopiuj",
  },
  {
    "reference": "string.Tekst.610",
    "text": "Eksportuj",
  },
  {
    "reference": "string.Tekst.611",
    "text": "Płaski (ten sam folder bez żadnej struktury folderów)",
  },
  {
    "reference": "string.Tekst.612",
    "text": "Od folderu głównego (root) dla wszystkich plików",
  },
  {
    "reference": "string.Tekst.613",
    "text": "Od pierwszego wspólnego folderu dla wszystkich plików",
  },
  {
    "reference": "string.Tekst.614",
    "text": "Zastąp",
  },
  {
    "reference": "string.Tekst.615",
    "text": "Dołącz z numerem kolejnym",
  },
  {
    "reference": "string.Tekst.616",
    "text": "Nie kopiuj pliku",
  },
  {
    "reference": "string.Tekst.617",
    "text": "Kopiuj tylko pojedyncze znalezione pozycje",
  },
  {
    "reference": "string.Tekst.618",
    "text": "Skopiuj nadrzędny plik",
  },
  {
    "reference": "string.Tekst.619",
    "text": "Kopiuj duplikaty",
  },
  {
    "reference": "string.Tekst.620",
    "text": "Utwórz skrót do oryginału",
  },
  {
    "reference": "string.Tekst.621",
    "text": "Błąd dziennika",
  },
  {
    "reference": "string.Tekst.622",
    "text": "Stop",
  },
  {
    "reference": "string.Tekst.623",
    "text": "Pytaj o akcję",
  },
  {
    "reference": "string.Tekst.624",
    "text": "Nie można utworzyć pliku",
  },
  {
    "reference": "string.Tekst.625",
    "text": "Kopiowanie",
  },
  {
    "reference": "string.Tekst.626",
    "text": "Błąd plików",
  },
  {
    "reference": "string.Tekst.627",
    "text": "Błąd kopiowania",
  },
  {
    "reference": "string.Tekst.628",
    "text": "Pomyślnie skopiowano pliki",
  },
  {
    "reference": "string.Tekst.629",
    "text": "Kopiowanie anulowane",
  },
  {
    "reference": "string.Tekst.630",
    "text": "lokalizacje",
  },
  {
    "reference": "string.Tekst.631",
    "text": "Kliknij dwukrotnie, aby edytować",
  },
  {
    "reference": "string.Tekst.632",
    "text": "Pliki tekstowe (*.txt)|*.txt|Wszystkie pliki (*.*)|*.*||",
  },
  {
    "reference": "string.Tekst.633",
    "text": "Zastąpić aktualny plik?",
  },
  {
    "reference": "string.Tekst.634",
    "text": "Skrypty",
  },
  {
    "reference": "string.Tekst.635",
    "text": "Kryteria wyszukiwania wykluczyły %s pozycje z listy",
  },
  {
    "reference": "string.Tekst.636",
    "text": "Wykluczone pliki",
  },
  {
    "reference": "string.Tekst.637",
    "text": "Nieprawidłowa lokalizacja",
  },
  {
    "reference": "string.Tekst.638",
    "text": "Odnotowane błędy",
  },
  {
    "reference": "string.Tekst.639",
    "text": "Przeszukiwanie podfolderów zostało wyłączone",
  },
  {
    "reference": "string.Tekst.640",
    "text": "Pole "Zawiera tekst" składa się tylko z białej przestrzeni",
  },
  {
    "reference": "string.Tekst.641",
    "text": "Ostrzeżenie",
  },
  {
    "reference": "string.Tekst.642",
    "text": "Ostrzeżenia generowane podczas wyszukiwania",
  },
  {
    "reference": "string.Tekst.643",
    "text": "Pliki Zip (*.zip)|*.zip|Wszystkie pliki (*.*)|*.*||",
  },
  {
    "reference": "string.Tekst.644",
    "text": "Rozróżnianie wielkości liter w "Nazwa pliku" jest włączone",
  },
  {
    "reference": "string.Tekst.645",
    "text": "Rozróżnianie wielkości liter w "Zawiera tekst" jest włączone",
  },
  {
    "reference": "string.Tekst.646",
    "text": "Treść wiadomości",
  },
  {
    "reference": "string.Tekst.647",
    "text": "E-mail",
  },
  {
    "reference": "string.Tekst.648",
    "text": "Strona",
  },
  {
    "reference": "string.Tekst.649",
    "text": "Raport kopii zbiorczej",
  },
  {
    "reference": "string.Tekst.650",
    "text": "Zapisywanie pliku",
  },
  {
    "reference": "string.Tekst.651",
    "text": "Ruchoma licencja: do %s jednoczesnych użytkowników",
  },
  {
    "reference": "string.Tekst.652",
    "text": "%s plik(ów) nie można było wyszukać",
  },
  {
    "reference": "string.Tekst.653",
    "text": "Kliknij, aby zobaczyć szczegóły",
  },
  {
    "reference": "string.Tekst.654",
    "text": "Wskaźnik dotkliwości",
  },
  {
    "reference": "string.Tekst.655",
    "text": "Szczegóły",
  },
  {
    "reference": "string.Tekst.656",
    "text": "Pokaż początek ścieżki",
  },
  {
    "reference": "string.Tekst.657",
    "text": "Pokaż koniec ścieżki",
  },
  {
    "reference": "string.Tekst.658",
    "text": "%s plik(i) zgłosił(y) ostrzeżenie wyszukiwania",
  },
  {
    "reference": "string.Tekst.659",
    "text": "Używany preset nazwy pliku",
  },
  {
    "reference": "string.Tekst.660",
    "text": "Dane GPS",
  },
  {
    "reference": "string.Tekst.661",
    "text": "Licencja grupowa. Maks. liczba użytkowników: %s",
  },
  {
    "reference": "string.Tekst.662",
    "text": "Wypakowywanie",
  },
  {
    "reference": "string.Tekst.663",
    "text": "Przeznaczenie",
  },
  {
    "reference": "string.Tekst.664",
    "text": "Nie skopiowane - pliki już istnieją w miejscu docelowym",
  },
  {
    "reference": "string.Tekst.665",
    "text": "Kopia zbiorcza",
  },
  {
    "reference": "string.Tekst.666",
    "text": "Eksportowanie wyników wyszukiwania",
  },
  {
    "reference": "string.Tekst.700",
    "text": "Wieloliniowy RegEx",
  },
  {
    "reference": "string.Tekst.701",
    "text": "Ekspert",
  },
  {
    "reference": "string.Tekst.702",
    "text": "Podstawowy",
  },
  {
    "reference": "string.Tekst.703",
    "text": "Wyszukiwanie zindeksowane",
  },
  {
    "reference": "string.Tekst.704",
    "text": "<Utwórz nowy indeks...>",
  },
  {
    "reference": "string.Tekst.705",
    "text": "Nie wybrano indeksu. Wybierz indeks i spróbuj ponownie.",
  },
  {
    "reference": "string.Tekst.706",
    "text": "Nieprawidłowy indeks",
  },
  {
    "reference": "string.Tekst.707",
    "text": "Nowy indeks",
  },
  {
    "reference": "string.Tekst.708",
    "text": "Synchronizowanie nazwy folderu z nazwą indeksu",
  },
  {
    "reference": "string.Tekst.709",
    "text": "Data i czas",
  },
  {
    "reference": "string.Tekst.710",
    "text": "Analizowanie",
  },
  {
    "reference": "string.Tekst.711",
    "text": "Zindeksowane: %s | Nie zindeksowane: %s | Błędy: %s | Nieważny: %s | Usunięte: %s | Bez zmian: %s",
  },
  {
    "reference": "string.Tekst.712",
    "text": "Rozpoczęcie procesu indeksowania",
  },
  {
    "reference": "string.Tekst.713",
    "text": "Szczegóły indeksu",
  },
  {
    "reference": "string.Tekst.714",
    "text": "Lista indeksów",
  },
  {
    "reference": "string.Tekst.715",
    "text": "Indeks",
  },
  {
    "reference": "string.Tekst.716",
    "text": "Zindeksowane",
  },
  {
    "reference": "string.Tekst.717",
    "text": "Czy na pewno chcesz usunąć: %s?",
  },
  {
    "reference": "string.Tekst.718",
    "text": "Czyszczenie indeks",
  },
  {
    "reference": "string.Tekst.719",
    "text": "Optymalizacja",
  },
  {
    "reference": "string.Tekst.720",
    "text": "Zapisywanie",
  },
  {
    "reference": "string.Tekst.721",
    "text": "...",
  },
  {
    "reference": "string.Tekst.722",
    "text": "Nie można wczytać indeksu",
  },
  {
    "reference": "string.Tekst.723",
    "text": "Anulowano",
  },
  {
    "reference": "string.Tekst.724",
    "text": "Standardowe lokalizacje dokumentów",
  },
  {
    "reference": "string.Tekst.725",
    "text": "Typy plików",
  },
  {
    "reference": "string.Tekst.726",
    "text": "Rozmiar indeksu: %s | Ilość zindeksowanych: %s | Tylko nazwa: %s | Łącznie: %s",
  },
  {
    "reference": "string.Tekst.727",
    "text": "Menedżer indeksów",
  },
  {
    "reference": "string.Tekst.728",
    "text": "Indeksy są obecnie aktualizowane. Czy chcesz anulować wszystkie procesy indeksowania ?",
  },
  {
    "reference": "string.Tekst.729",
    "text": "Nie można zindeksować",
  },
  {
    "reference": "string.Tekst.730",
    "text": "Plik binarny zignorowany",
  },
  {
    "reference": "string.Tekst.731",
    "text": "Indeks jest w trybie tylko do odczytu.",
  },
  {
    "reference": "string.Tekst.732",
    "text": "Nie można wyszukać pliku.",
  },
  {
    "reference": "string.Tekst.733",
    "text": "Podstawowa metoda wyszukiwania zawiodła, zastosowano wyszukiwanie danych nieprzetworzonych.",
  },
  {
    "reference": "string.Tekst.734",
    "text": "Wyszukiwana fraza wygląda jak wyrażenie Listy plików, ale opcja konfiguracji jest wyłączona.",
  },
  {
    "reference": "string.Tekst.735",
    "text": "Nazwa pliku wygląda jak wyrażenie listy plików, ale opcja konfiguracji jest wyłączona.",
  },
  {
    "reference": "string.Tekst.736",
    "text": "Wyszukiwane wyrażenie zostało sprawdzone metodą linia po linii, jak określono na karcie "Opcje".",
  },
  {
    "reference": "string.Tekst.737",
    "text": "Linie otaczające",
  },
  {
    "reference": "string.Tekst.738",
    "text": "Znacznik otaczający linii",
  },
  {
    "reference": "string.Tekst.739",
    "text": "Trafione linie",
  },
  {
    "reference": "string.Tekst.740",
    "text": "Przecinki użyte w wyrażeniu wieloznacznym, czy miał być średnik?",
  },
  {
    "reference": "string.Tekst.741",
    "text": "Punkt ponownej analizy",
  },
  {
    "reference": "string.Tekst.742",
    "text": "Wymagana aktualizacja - ustawienia indeksu nie są zgodne",
  },
  {
    "reference": "string.Tekst.743",
    "text": "Indeks nie obsługuje wyszukiwań uwzględniających wielkość liter. Aby włączyć tę opcję, musisz przebudować indeks z włączonym rozróżnianiem wielkości liter.",
  },
  {
    "reference": "string.Tekst.744",
    "text": "Nie można rozpocząć wyszukiwania",
  },
  {
    "reference": "string.Tekst.745",
    "text": "Rozróżnianie wielkości liter jest włączone",
  },
  {
    "reference": "string.Tekst.746",
    "text": "Indeks jest nieaktualny, wyszukiwanie zostało uruchomione przy użyciu starych ustawień indeksu.",
  },
  {
    "reference": "string.Tekst.747",
    "text": "Nie można wyświetlić trafień dla pliku.",
  },
  {
    "reference": "string.Tekst.748",
    "text": "Wyszukiwanie zostało przedwcześnie anulowane",
  },
  {
    "reference": "string.Tekst.749",
    "text": "Pusty indeks",
  },
  {
    "reference": "string.Tekst.750",
    "text": "Nigdy",
  },
  {
    "reference": "string.Tekst.751",
    "text": "Indeks jest pusty, użyj "Menedżera nideksów" aby utworzyć indeks.",
  },
  {
    "reference": "string.Tekst.752",
    "text": "Pliki binarne wykluczone",
  },
  {
    "reference": "string.Tekst.753",
    "text": "Unikalne słowa kluczowe",
  },
  {
    "reference": "string.Tekst.754",
    "text": "Nieprawidłowa data. Czas dla pliku systemowego nie może być wcześniejszy niż 1601.",
  },
  {
    "reference": "string.Tekst.755",
    "text": "Plik został tylko częściowo przeszukany ze względu na liczbę znalezionych linii przekraczających określone maksimum.",
  },
  {
    "reference": "string.Tekst.756",
    "text": "Przetwarzanie operatora FILELIST wygenerowało błąd",
  },
  {
    "reference": "string.Tekst.757",
    "text": "Kolory",
  },
  {
    "reference": "string.Tekst.758",
    "text": "Inne...",
  },
  {
    "reference": "string.Tekst.759",
    "text": "Wątki wyszukiwania",
  },
  {
    "reference": "string.Tekst.760",
    "text": "Potwierdź działanie",
  },
  {
    "reference": "string.Tekst.761",
    "text": "Nie pokazuj ponownie tej wiadomości",
  },
  {
    "reference": "string.Tekst.762",
    "text": "Ostrzeżenie: Duży plik",
  },
  {
    "reference": "string.Tekst.763",
    "text": "Wybrany plik jest bardzo duży i jego otwarcie może spowolnić program lub program może przestać odpowiadać.",
  },
  {
    "reference": "string.Tekst.764",
    "text": "** ANULOWANO WCZYTYWANIE PLIKU **",
  },
  {
    "reference": "string.Tekst.765",
    "text": "Pokaż szczegóły >>",
  },
  {
    "reference": "string.Tekst.766",
    "text": "<< Ukryj szczegóły",
  },
  {
    "reference": "string.Tekst.767",
    "text": "Aby ta funkcja działała, program musi włączyć rozszerzenia przeglądarki innej firmy w programie Internet Explorer i zanim zacznie działać, konieczne będzie ponowne uruchomienie. 

Czy chcesz kontynuować?",
  },
  {
    "reference": "string.Tekst.768",
    "text": "Nie określono indeksu.",
  },
  {
    "reference": "string.Tekst.769",
    "text": "Nie określono operacji indeksu.",
  },
  {
    "reference": "string.Tekst.770",
    "text": "Czas trwania (sek.)",
  },
  {
    "reference": "string.Tekst.771",
    "text": "Wątki wyszukiwania",
  },
  {
    "reference": "string.Tekst.772",
    "text": "Anuluj",
  },
  {
    "reference": "string.Tekst.773",
    "text": "Aktualnie brak uruchomionych wątków wyszukiwania zawartość dla tego wyszukiwania",
  },
  {
    "reference": "string.Tekst.774",
    "text": "Nie określono lokalizacji do indeksowania. Określ, które lokalizacje powinny być indeksowane.",
  },
  {
    "reference": "string.Tekst.775",
    "text": "Nie określono zawartości do indeksowania. Proszę określić, które pliki powinny znaleźć się w indeksie.",
  },
  {
    "reference": "string.Tekst.776",
    "text": "Lista indeksów jest zablokowana dla aktualizacji przez inną aplikację",
  },
  {
    "reference": "string.Tekst.777",
    "text": "Naciśnij "Zakończ" aby zakończyć.",
  },
  {
    "reference": "string.Tekst.778",
    "text": "Nie można uruchomić Manadżera indeksu",
  },
  {
    "reference": "string.Tekst.779",
    "text": "Kompletowanie częściowych wyników wyszukiwania...",
  },
  {
    "reference": "string.Tekst.780",
    "text": "Rozmyte",
  },
  {
    "reference": "string.Tekst.781",
    "text": "Lokalizacja wybrana do przechowywania bazy danych indeksów musi być nowym lub pustym folderem.",
  },
  {
    "reference": "string.Tekst.782",
    "text": "Wystąpił problem z bieżącą operacją. Zwykle dzieje się tak z powodu ustawienia "Osobny podgląd każdej karty na pasku zadań" w ustawieniach "Interfejs użytkownika". Jeśli problem nadal występuje, wyłącz tę opcję.",
  },
  {
    "reference": "string.Tekst.783",
    "text": "Utwórz ponownie indeks",
  },
  {
    "reference": "string.Tekst.784",
    "text": "Zaktualizuj indeks",
  },
  {
    "reference": "string.Tekst.785",
    "text": "Utwórz nowy indeks",
  },
  {
    "reference": "string.Tekst.786",
    "text": "Nie określono nazwy indeksu.",
  },
  {
    "reference": "string.Tekst.787",
    "text": "Nie określono ścieżki indeksu.",
  },
  {
    "reference": "string.Tekst.788",
    "text": "Jeśli zmienisz typ kryteriów podczas wyszukiwania, bieżące wyszukiwanie zostanie anulowane. Czy chcesz anulować bieżące wyszukiwanie?",
  },
  {
    "reference": "string.Tekst.789",
    "text": "Indeksowanie",
  },
  {
    "reference": "string.Tekst.790",
    "text": "Ścieżka została wykluczona z wyszukiwania z powodu aktywnych wykluczeń ścieżek i/lub filtrów",
  },
  {
    "reference": "string.Tekst.791",
    "text": "Pusty plik, nie znaleziono szukanego tekstu",
  },
  {
    "reference": "string.Tekst.792",
