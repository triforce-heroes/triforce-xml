  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.caption",
    "text": "Nazwa pliku",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.1",
    "text": "Jaka jest nazwa pliku, który chcesz znaleźć?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.2",
    "text": "Nie znasz dokładnej nazwy? Nie martw się, możesz wyszukiwać fragmenty nazw. Jeśli nie znasz żadnego fragmentu nazwy, pozostaw to pole puste.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.3",
    "text": "Przykłady:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.4",
    "text": "Moje*Arch",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.5",
    "text": "Znajdzie wszystkie dokumenty zawierające "Moje" oraz jeszcze "Arch" gdzieś dalej w nazwie",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.6",
    "text": "(np. Moje_Archiwum.doc, Moje_Autoarchiwum.txt  itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.7",
    "text": "Przed użyciem wyrażeń podobnych do tych pokazanych w przykładach, upewnij się, że nazwa pliku jest ustawiona na "Symbole wieloznaczne" na karcie "Opcje".",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.8",
    "text": "MojeArch",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.9",
    "text": "Znajdzie wszystkie dokumenty zawierające MojeArch gdzieś w nazwie",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.10",
    "text": "(np. MojeArchiwum.doc, Uwagi_MojeArchiwa.txt  itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.11",
    "text": "*.doc;*.txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.12",
    "text": "Znajdzie wszystkie pliki .doc lub .txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.13",
    "text": "(np. Moje_dokumenty.doc, Opis programu.txt  itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.caption",
    "text": "Lokalizacja pliku",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.1",
    "text": "&Wszystkie lokalne dyski twarde",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.2",
    "text": "Określony &dysk (np. C:, D: itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.3",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.4",
    "text": "Określony &folder (np. C:\Windows, D:\Files\My Docs itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.6",
    "text": "&Przeglądaj...",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.7",
    "text": "&Tak, szukaj również w podfolderach",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.8",
    "text": "&Nie, przeszukuj tylko ten folder",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.9",
    "text": "&Rozpocznij wyszukiwanie automatycznie po kliknięciu przycisku Zakończ",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.10",
    "text": "Gdzie chcesz szukać pliku ?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.11",
    "text": "Czy chcesz również przeszukiwać podfoldery folderów ?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.12",
    "text": "Wskazówka dotycząca wydajności: Wybór konkretnego folderu znacznie zmniejsza liczbę plików do przeszukania, a więc zwykle jest znacznie szybsze.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.caption",
    "text": "Zawartość pliku",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.1",
    "text": "Czy chcesz wyszukać plik na podstawie tekstu zawartego w pliku?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.2",
    "text": "&Nie, po prostu wyszukaj według nazwy pliku",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.3",
    "text": "&Tak, wyszukaj zawartość pliku",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.4",
    "text": "Jaki tekst powinien zawierać plik?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.5",
    "text": "Przykłady:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.6",
    "text": ""Moje Miasto"",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.7",
    "text": "Znajdzie dowolny plik, który zawiera wiersz z wyrażeniem "Moje Miasto".",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.8",
    "text": "(np. Moje Miasto..., To jest Moje Miasto... itp.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.9",
    "text": "Moje Miasto",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.10",
    "text": "Znajdzie dowolny plik, który zawiera obydwa słowa "Moje" oraz "Miasto" (np. Oto Moje Miasto..., które nigdy nie zasypia...)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.11",
    "text": "Wskazówka dotycząca wydajności: Wyszukiwanie zawartości plików może zająć dużo czasu, zwłaszcza jeśli nazwa nie została wprowadzona lub nie jest zbyt szczegółowa. Dlatego wybór "Nie" jest zwykle znacznie szybszą opcją.",
  },
