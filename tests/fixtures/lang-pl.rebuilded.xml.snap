    "reference": "string.Tekst.387",
    "text": "Duże ikony",
  },
  {
    "reference": "string.Tekst.388",
    "text": "Bardzo duże ikony",
  },
  {
    "reference": "string.Tekst.389",
    "text": "Podgląd",
  },
  {
    "reference": "string.Tekst.390",
    "text": "Pokazuję raport podsumowania",
  },
  {
    "reference": "string.Tekst.391",
    "text": "Czy chcesz usunąć także wszystkie dane użytkownika powiązane z programem?",
  },
  {
    "reference": "string.Tekst.392",
    "text": "Usuń dane użytkownika",
  },
  {
    "reference": "string.Tekst.393",
    "text": "Usunięto błąd",
  },
  {
    "reference": "string.Tekst.394",
    "text": "Nie można przetłumaczyć okna dialogowego",
  },
  {
    "reference": "string.Tekst.395",
    "text": "Czy na pewno chcesz usunąć ulubiony '%s'?",
  },
  {
    "reference": "string.Tekst.396",
    "text": "Skrypt %s jest nieprawidłowy.

Dodatkowe informacje:

%s",
  },
  {
    "reference": "string.Tekst.397",
    "text": "Czy na pewno chcesz usunąć filtr wyszukiwania '%s'?",
  },
  {
    "reference": "string.Tekst.398",
    "text": "IFiltry",
  },
  {
    "reference": "string.Tekst.399",
    "text": "W dół",
  },
  {
    "reference": "string.Tekst.400.regex",
    "text": "początek",
  },
  {
    "reference": "string.Tekst.401.regex",
    "text": "dzisiaj",
  },
  {
    "reference": "string.Tekst.402.regex",
    "text": "teraz",
  },
  {
    "reference": "string.Tekst.403.regex",
    "text": "sek.*",
  },
  {
    "reference": "string.Tekst.404.regex",
    "text": "min.*",
  },
  {
    "reference": "string.Tekst.405.regex",
    "text": "m.*",
  },
  {
    "reference": "string.Tekst.406.regex",
    "text": "godz.*",
  },
  {
    "reference": "string.Tekst.407.regex",
    "text": "d.*",
  },
  {
    "reference": "string.Tekst.408.regex",
    "text": "t.*",
  },
  {
    "reference": "string.Tekst.409.regex",
    "text": "l.*",
  },
  {
    "reference": "string.Tekst.410.regex",
    "text": "\b(dzisiaj)|(początek|koniec) *(?: +(?:the|of|this))* +(t|m|l)[a-z]*",
  },
