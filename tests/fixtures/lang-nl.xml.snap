  {
    "reference": "dialog.IDD_EXPR_WIZ.caption",
    "text": "Maak de uitdrukking",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.1",
    "text": "occurs",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.2",
    "text": "&Toevoegen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.3",
    "text": "&Veranderen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.4",
    "text": "&Verwijderen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.5",
    "text": "List2",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.6",
    "text": "Resultaat uitdrukking",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ.7",
    "text": "Opmerking: slepen en neerzetten om items opnieuw in te delen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.caption",
    "text": "Introductie van de uitdrukkingen hulp",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.1",
    "text": "Welkom bij de uitdrukkingen hulp. Met deze hulp kunt u precies bepalen waarnaar u op zoek bent..",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.2",
    "text": "Standaard uitdrukkingen worden gebruikt om patronen voor tekenreeksen te beschrijven. Hoewel standaard uitdrukkingen expressies erg krachtig zijn, zijn ze ook vaak ontmoedigend voor de niet specialisten onder ons.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.3",
    "text": "Het doel van uitzonderingen hulp is daarom om de complexiteit van standaard uitdrukkingen te verminderen zonder de kracht hiervan te hoeven op te offeren. Uitzonderingen hulp zal helpen de uitdrukking voor u op te bouwen door u te vragen om deze te beschrijven.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.4",
    "text": "Opmerking:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.5",
    "text": "De zoek specifieke notitie gaat naar hier.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.6",
    "text": "&Laat deze introductie de volgende keer niet meer zien.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.caption",
    "text": "Waarschuwing: speciale karakters ingevoerd ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.1",
    "text": "&Ja; voeg de juiste backslashes toe omdat geen van de tekens die ik heb ingevoerd moet worden behandeld als een speciaal teken.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.2",
    "text": "&Nee, ik gebruik bewust speciale tekens voor geavanceerd zoeken.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.3",
    "text": "Een of meer van de uitdrukkingen die u hebt ingevoerd, bevat ten minste één van de volgende speciale tekens: ^$*?+.[]()|\ ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.4",
    "text": "Speciale tekens worden gebruikt in standaard uitdrukkingen om de overeenkomstige regels te definiëren en moeten daarom met voorzichtigheid worden gebruikt. Als u wilt zoeken naar een teken dat een speciaal teken is dan moet u er een backslash vóór plaatsen. ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.6",
    "text": "Als voorbeeld:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.7",
    "text": "Zoeken naar:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.8",
    "text": "de uitdrukking zou zijn:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.9",
    "text": "$400.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.10",
    "text": "\$400\.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.11",
    "text": "Wat was dat?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.12",
    "text": "Wat was dat\?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.13",
    "text": "(12\4)*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.14",
    "text": "\(12\\4\)\*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.15",
    "text": "Zoeken naar:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.16",
    "text": "Zoeken naar:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.17",
    "text": "de uitdrukking zou zijn:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.18",
    "text": "de uitdrukking zou zijn:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.19",
    "text": "Wilt u dat de uitdrukkingen hulp automatisch backslashes invoegt vóór alle speciale tekens?",
  },
  {
    "reference": "dialog.IDD_OPTIONS.caption",
    "text": "Opties",
  },
  {
    "reference": "dialog.IDD_OPTIONS.1",
    "text": "Specificeert de &NOT uitdrukking",
  },
  {
    "reference": "dialog.IDD_OPTIONS.2",
    "text": "&Gelijk aan",
  },
  {
    "reference": "dialog.IDD_OPTIONS.3",
    "text": "Gelijk &aan",
  },
  {
    "reference": "dialog.IDD_OPTIONS.4",
    "text": " Bestandsnaam ",
  },
  {
    "reference": "dialog.IDD_OPTIONS.5",
    "text": " Inhoud ",
  },
  {
    "reference": "dialog.IDD_OPTIONS.6",
    "text": "Zoek in",
  },
