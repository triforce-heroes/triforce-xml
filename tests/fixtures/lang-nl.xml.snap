    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.caption",
    "text": "DOS uitdrukkingen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.1",
    "text": "Uitdrukkingen met jokertekens gebruiken de standaard Windows-syntaxis voor het specificeren van een groep bestanden. Een puntkomma wordt gebruikt om meerdere uitdrukkingen te scheiden.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.2",
    "text": "Voorbeeld:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.3",
    "text": "*.txt		Specificeert alle bestanden met een txt extensie

*.xls;*.doc	Specificeert alle bestanden met een .xls of een .doc extensie",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.4",
    "text": "Geavanceerde voorbeelden:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.5",
    "text": "*.png;*.jpg:vissen		Specificeert alle .png en jpg bestanden met het woord vissen in de naam

NOT:*.doc;*.xls			Specificeert alle bestanden behalve .doc and .xls bestanden

vis;NOT:*.exe;*.dll		specificeert alle bestanden behalve .exe of .dll met het woord vis in de naam",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.caption",
    "text": "Boolean uitdrukkingen opdracht",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.1",
    "text": "Boolean uitdrukkingen maken gebruik van de webstijlzoekoperators AND OR NOT, LIKE en NEAR. Boolean zoekopdrachten kunnen per regel of per bestand zijn:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.2",
    "text": "Voorbeeld:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.3",
    "text": "werk AND document	Zoekt naar de woorden 'werk' en 'document' in dezelfde regel of bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.4",
    "text": "werk document		Gebruikt dezelfde zoek opdracht al hierboven (de AND is onvoorwaardelijk)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.5",
    "text": "werk OR document	Zoekt naar de woorden 'werk' of 'document' in dezelfde regel of bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.6",
    "text": "werk NEAR document	Zoekt naar 'werk' in de buurt van het woord 'document' in een regel of bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.7",
    "text": ""werk document"	Zoekt naar de exacte woordcombinatie 'werk document'",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.8",
    "text": "Op regel",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.9",
    "text": "Uitdrukking wordt afzonderlijk uitgevoerd op elke individuele regel",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.10",
    "text": "Op bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.11",
    "text": "Uitdrukking wordt uitgevoerd in het gehele bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.12",
    "text": "Opmerking: gebruik haakjes om de uitdrukking te groeperen, b.v. (werk AND doc) OR (speciaal AND patat)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.caption",
    "text": "Boolean uitdrukkingen opdracht",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.1",
    "text": "Boolean uitdrukkingen maken gebruik van de webstijlzoekoperators AND, OR, en NOT. Boolean zoekopdrachten zijn in het hele bestand.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.2",
    "text": "Voorbeeld:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.3",
    "text": "werk AND document	Zoekt naar de woorden 'werk' en 'document' in dezelfde regel of bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.4",
    "text": "werk document		Gebruikt dezelfde zoek opdracht als hierboven (de AND is onvoorwaardelijk)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.5",
    "text": "werk OR document	Zoekt naar de woorden 'werk' of 'document' in hetzelfde bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.6",
    "text": "werk NOT document	Zoekt naar 'werk' zonder het woord 'document' in hetzelfde bestand",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.7",
    "text": ""werk document"	Zoekt naar de exacte woordcombinatie 'werk document'",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.8",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.9",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.10",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.11",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.12",
    "text": "Opmerking: gebruik haakjes om de uitdrukking te groeperen, b.v. (werk AND doc) OR (speciaal AND patat)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.caption",
    "text": "Platte tekst",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.1",
    "text": "Met Platte tekst wordt de tekst van de zoekcriteria behandeld als een letterlijke waarde, d.w.z. precies zoals de tekst in het bewerkingsveld is ingevoerd. De zoekcriteria komen overeen met het geheel of een deel van een woord.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.2",
    "text": "Voorbeeld:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.3",
    "text": "de schrijver	zou zinnen moeten vinden met 'de schrijver' of 'de schrijvers'.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.4",
    "text": "vis		gelijk of tegenaan 'vis', 'vissen', or 'gevist'.",
  },
