  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.caption",
    "text": "Bestandsnaam",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.1",
    "text": "Wat is de naam van het bestand dat u wilt vinden?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.2",
    "text": "U weet de exacte naam niet? Geen zorgen, u kunt zoeken op delen van de naam. Als u niets weet van de naam, laat het dan leeg.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.3",
    "text": "Voorbeelden:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.4",
    "text": "My*Doc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.5",
    "text": "Zou alle documenten met My dan Doc ergens in de naam moeten vinden",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.6",
    "text": "(b.v. My_Document.doc, My_Autodoc.txt enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.7",
    "text": "Make sure the file name is set to Wildcard expression in the options tab before using expressions like those shown in the examples.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.8",
    "text": "MyDoc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.9",
    "text": "Zou alle documenten met MyDoc ergens in de naam moeten vinden",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.10",
    "text": "(b.v. MyDocument.doc, Note_From_MyDoctor.txt enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.11",
    "text": "*.doc;*.txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.12",
    "text": "Zou alle .doc of .txt bestanden moeten vinden",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.13",
    "text": "(b.v. MyDocument.doc, DoctorsNote.txt enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.caption",
    "text": "Plaats van bestand",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.1",
    "text": "&Alle lokale harde schijven",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.2",
    "text": "Specifieke schijf (b.v. C:, D: enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.3",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.4",
    "text": "Specifieke &map (b.v. C:\Windows, D:\Files\My Docs enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.6",
    "text": "&Bladeren...",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.7",
    "text": "&Ja, ook in de onderliggende mappen zoeken",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.8",
    "text": "&Nee, alleen in die map zoeken",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.9",
    "text": "&Start het zoeken automatisch wanneer u op de knop Voltooien klikt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.10",
    "text": "Waar wilt u naar het bestand zoeken?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.11",
    "text": "Wilt u ook in de onderliggende mappen van de map zoeken?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.12",
    "text": "Prestatietip: door een bepaalde map te kiezen, wordt het aantal bestanden dat moet worden opgezocht aanzienlijk beperkt en dat gaat meestal veel sneller.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.caption",
    "text": "Inhoud van het bestand",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.1",
    "text": "Wilt u naar het bestand zoeken op basis van tekst in het bestand?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.2",
    "text": "&Nee, zoek alleen op bestandsnaam",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.3",
    "text": "&Ja; zoek de inhoud van het bestand",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.4",
    "text": "Welke tekst moet het bestand bevatten?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.5",
    "text": "Voorbeelden:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.6",
    "text": ""Beste Bill"",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.7",
    "text": "Zou een bestand moeten vinden met Beste Bill erin.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.8",
    "text": "(b.v. Beste Bill ..., beste Billy, hoe gaat het met jou enz.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.9",
    "text": "Beste Bill",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.10",
    "text": "Zou een bestand moeten vinden met de woorden Beste en Bill erin (b.v. Beste Fred, hoe is Bill ..., De worden hoeven elkaar niet op te volgen)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.11",
    "text": "Prestatietip: het doorzoeken van de inhoud van bestanden kan lang duren, vooral als een naam niet is ingevoerd of niet erg specifiek is. Daarom is het kiezen van Nee meestal veel sneller",
  },
  {
