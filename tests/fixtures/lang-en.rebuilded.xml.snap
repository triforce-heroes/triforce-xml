    "reference": "dialog.IDD_SEARCH_WIZ_NAME.7",
    "text": "Make sure the file name is set to Wildcard expression in the options tab before using expressions like those shown in the examples.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.8",
    "text": "MyDoc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.9",
    "text": "Would find all documents with MyDoc somwhere in the name",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.10",
    "text": "(e.g. MyDocument.doc, Note_From_MyDoctor.txt etc.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.11",
    "text": "*.doc;*.txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.12",
    "text": "Would find all .doc or .txt files",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.13",
    "text": "(e.g. MyDocument.doc, DoctorsNote.txt etc.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.caption",
    "text": "Location of file",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.1",
    "text": "&All local hard drives",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.2",
    "text": "Specific &drive (e.g. C:, D: etc.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.3",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.4",
    "text": "Specific &folder (e.g. C:\Windows, D:\Files\My Docs etc.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.6",
    "text": "&Browse...",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.7",
    "text": "&Yes, also search the sub folders",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.8",
    "text": "&No, only search that folder",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.9",
    "text": "&Start the search automatically when you click the Finish button",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.10",
    "text": "Where do you want to search for the file?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.11",
    "text": "Do you want to search the folder's sub folders as well?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.12",
    "text": "Performance tip: Choosing a specific folder greatly reduces the number of files to be searched and so is usually much faster.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.caption",
    "text": "Contents of file",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.1",
    "text": "Do you want to search for the file based upon text within the file?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.2",
    "text": "&No, just search by file name",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.3",
    "text": "&Yes, search the contents of the file",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.4",
    "text": "What text should the file contain?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.5",
    "text": "Examples:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.6",
    "text": ""Dear Bill"",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.7",
    "text": "Would find any file that had a line with the phrase Dear Bill in it.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.8",
    "text": "(e.g. My Dear Bill..., Dear Billy how are you... etc.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.9",
    "text": "Dear Bill",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.10",
    "text": "Would find any file that had both the words Dear and Bill in it (e.g. Dear Fred how is Bill..., The dearest items should be rebilled...)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.11",
    "text": "Performance tip: Searching the contents of files can take a long time, especially if a name has not been entered or is not very specific. Therefore, choosing No is usually much faster.",
  },
