  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.caption",
    "text": "Introducing the Expression Wizard",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.1",
    "text": "Welcome to the Expression Wizard. This wizard will help you define exactly what you are looking for.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.2",
    "text": "Regular expressions are used to describe patterns for string matching. While regular expressions are very powerful they also tend to be daunting for the uninitiated.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.3",
    "text": "Expression Wizard's purpose is therefore to reduce the complexity of regular expressions without sacrificing the power. Expression Wizard will help build the expression for you by asking you to describe what you are looking in terms easier to understand.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.4",
    "text": "Note:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.5",
    "text": "The search specific note goes here.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_INTRO.6",
    "text": "&Don't show this introduction next time.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.caption",
    "text": "Warning: Special characters entered",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.1",
    "text": "&Yes. Please insert appropriate backslashes because none of the characters I entered should be treated as special characters.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.2",
    "text": "&No. I am deliberately using special characters for advanced searching.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.3",
    "text": "One or more of the expressions you entered contains at least one of the following special characters: ^$*?+.[]()|\ ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.4",
    "text": "Special characters are used in regular expressions to define the pattern matching rules and therefore should be used with caution. If you want to search for a character that is also a special character that you must put a backslash before the character. ",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.6",
    "text": "For example:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.7",
    "text": "To search for:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.8",
    "text": "the expression would be:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.9",
    "text": "$400.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.10",
    "text": "\$400\.00",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.11",
    "text": "What was that?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.12",
    "text": "What was that\?",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.13",
    "text": "(12\4)*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.14",
    "text": "\(12\\4\)\*5=15",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.15",
    "text": "To search for:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.16",
    "text": "To search for:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.17",
    "text": "the expression would be:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.18",
    "text": "the expression would be:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_SPECIAL.19",
    "text": "Would you like Expression Wizard to automatically insert the backslashes before all special characters?",
  },
  {
