  {
    "reference": "string.Metin.660",
    "text": "GPS Verileri",
  },
  {
    "reference": "string.Metin.661",
    "text": "Site Lisansı. Maksimum kullanıcılar: %s",
  },
  {
    "reference": "string.Metin.662",
