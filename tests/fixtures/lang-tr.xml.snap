  },
  {
    "reference": "dialog.IDD_BASIC.4",
    "text": "&Bak:",
  },
  {
    "reference": "dialog.IDD_BASIC.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_BASIC.6",
    "text": "Arama &Alt klasör",
  },
  {
    "reference": "dialog.IDD_BASIC.7",
    "text": "&Göz at...",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.caption",
    "text": "Dosya adı",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.1",
    "text": "Bulmak istediğiniz dosyanın adı nedir?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.2",
    "text": "Tam adını bilmiyor musunuz? Endişelenmeyin, adın bazı bölümlerinde arama yapabilirsiniz. Adın herhangi bir bölümünü bilmiyorsanız boş bırakın.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.3",
    "text": "Örnekler:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.4",
    "text": "My*Doc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.5",
    "text": "Benim ve sonra doc başka bir yerde adı olan tüm belgeleri bulmak mı istiyorsunuz?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.6",
    "text": "(ör. My_Document.doc, My_Autodoc.txt vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.7",
    "text": "Örneklerde gösterilenler gibi ifadeleri kullanmadan önce, seçenekler sekmesinde dosya adının Wildcard karakter ifadesi olarak ayarlandığından emin olun.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.8",
    "text": "MyDoc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.9",
    "text": "MyDoc somwhere adı ile tüm belgeleri bulmak istiyorsunuz",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.10",
    "text": "(ör. MyDocument.doc, Note_From_MyDoctor.txt vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.11",
    "text": "*.doc;*.txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.12",
    "text": "Tüm bulmak .doc or .txt dosyaları",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.13",
    "text": "(ör. MyDocument.doc, DoctorsNote.txt vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.caption",
    "text": "Dosyanın konumu",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.1",
    "text": "&Tüm yerel sabit diskler",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.2",
    "text": "Belirli &Sürücü (ör. C:, D: vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.3",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.4",
    "text": "Belirli &Klasör (ör. C:\Windows, D:\Files\My Docs vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.6",
    "text": "&Göz at...",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.7",
    "text": "&Evet, ayrıca alt klasörleri arama",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.8",
    "text": "&Hayır, sadece bu klasörü ara",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.9",
    "text": "&Son düğmesini tıklattığınızda aramayı otomatik olarak başlatma",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.10",
    "text": "Dosyayı nerede aramak istiyorsunuz?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.11",
    "text": "Klasörün alt klasörlerini de aramak istiyor musunuz?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.12",
    "text": "Performans ipucu: Belirli bir klasör seçmek, aranacak dosya sayısını büyük ölçüde azaltır ve bu nedenle genellikle çok daha hızlıdır.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.caption",
    "text": "Dosyanın içeriği",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.1",
    "text": "Dosyayı dosya içindeki metne göre aramak istiyor musunuz?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.2",
    "text": "&Hayır, sadece dosya adına göre ara",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.3",
    "text": "&Evet, dosyanın içeriğini ara",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.4",
    "text": "Dosyanın hangi metni içermesi gerekir?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.5",
    "text": "Örnekler:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.6",
    "text": ""Sevgili Bill"",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.7",
    "text": "İçinde Sevgili Bill ifadesinin olduğu bir satırı olan herhangi bir dosyayı bulurdum.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.8",
    "text": "(ör. Sevgili Bill..., Sevgili Billy, nasılsın... vb.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.9",
    "text": "Sevgili Bill",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.10",
    "text": "İçinde hem Sevgili hem de Bill kelimelerinin bulunduğu herhangi bir dosyayı bulabilirim (örneğin, Sevgili Fred  Bill nasıl..., En sevgili öğeler yeniden faturalandırılmalıdır...)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.11",
    "text": "Performans ipucu: Dosyaların içeriğinin aranması, özellikle bir ad girilmemişse veya çok belirgin değilse, uzun zaman alabilir. Bu nedenle, Hayır'ı seçmek genellikle çok daha hızlıdır.",
  },
  {
    "reference": "dialog.IDD_REGISTER.caption",
    "text": "Ürün Kaydı",
  },
  {
    "reference": "dialog.IDD_REGISTER.1",
