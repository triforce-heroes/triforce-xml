  },
  {
    "reference": "string.Metin.663",
    "text": "Hedef",
  },
  {
    "reference": "string.Metin.664",
    "text": "Kopyalanmadı - dosyalar hedefte zaten var",
  },
  {
    "reference": "string.Metin.665",
    "text": "Toplu kopyalama",
  },
  {
    "reference": "string.Metin.666",
    "text": "Dışa aktarma sonuçları",
  },
  {
    "reference": "string.Metin.700",
    "text": "Çok satırlı RegEx",
  },
  {
    "reference": "string.Metin.701",
    "text": "Uzman",
  },
  {
    "reference": "string.Metin.702",
    "text": "Temel",
  },
  {
    "reference": "string.Metin.703",
    "text": "Dizin Arama",
  },
  {
    "reference": "string.Metin.704",
    "text": "<Yeni Dizin Oluşturma...>",
  },
  {
    "reference": "string.Metin.705",
    "text": "Dizin seçili değil. Lütfen bir dizin seçin ve tekrar deneyin.",
  },
  {
    "reference": "string.Metin.706",
    "text": "Geçersiz Dizin",
  },
  {
    "reference": "string.Metin.707",
    "text": "Yeni Dizin",
  },
  {
    "reference": "string.Metin.708",
    "text": "Dizin adı ile klasör adını eşitleme",
  },
  {
    "reference": "string.Metin.709",
    "text": "Zaman",
  },
  {
    "reference": "string.Metin.710",
    "text": "Analiz",
  },
  {
    "reference": "string.Metin.711",
    "text": "Indexed: %s | Name only: %s | Errors: %s | Invalid: %s | Removed: %s | Unchanged: %s",
  },
  {
    "reference": "string.Metin.712",
    "text": "Dizin oluşturma işlemini başlatma",
  },
  {
    "reference": "string.Metin.713",
    "text": "Dizin Ayrıntıları",
  },
  {
    "reference": "string.Metin.714",
    "text": "Dizin Listesi",
  },
  {
    "reference": "string.Metin.715",
    "text": "Dizin",
  },
  {
    "reference": "string.Metin.716",
    "text": "Dizine",
  },
  {
    "reference": "string.Metin.717",
    "text": "Silmek istediğinizden emin misiniz: %s?",
  },
  {
    "reference": "string.Metin.718",
    "text": "Temizlik Endeksi",
  },
  {
    "reference": "string.Metin.719",
    "text": "Optimize",
  },
  {
    "reference": "string.Metin.720",
    "text": "Kaydedildi",
  },
  {
    "reference": "string.Metin.721",
    "text": "...",
  },
  {
    "reference": "string.Metin.722",
    "text": "Dizin yüklenemiyor",
  },
  {
    "reference": "string.Metin.723",
    "text": "İptal",
  },
  {
    "reference": "string.Metin.724",
    "text": "Standart belge konumları",
  },
  {
    "reference": "string.Metin.725",
    "text": "Dosya türleri",
  },
  {
    "reference": "string.Metin.726",
    "text": "Index size: %s | Indexed count: %s | Name only: %s | Total: %s",
  },
  {
    "reference": "string.Metin.727",
    "text": "Dizin Yöneticisi",
  },
  {
    "reference": "string.Metin.728",
    "text": "Dizinler şu anda güncellenmektedir. Tüm indeksleme işlemlerini iptal etmek ister misiniz?",
  },
  {
    "reference": "string.Metin.729",
    "text": "Dizin oluşturulamadı",
  },
  {
    "reference": "string.Metin.730",
    "text": "İkili dosya yoksayıldı",
  },
  {
    "reference": "string.Metin.731",
    "text": "Dizin salt okunur modda.",
  },
  {
    "reference": "string.Metin.732",
    "text": "Dosya arama yapılamıyor .",
  },
  {
    "reference": "string.Metin.733",
    "text": "Birincil arama yöntemi başarısız oldu, ham veri araması kullanıldı.",
  },
  {
    "reference": "string.Metin.734",
    "text": "Arama terimi bir dosya listesi ifadesine benziyor ancak yapılandırma seçeneği kapatılıyor.",
  },
  {
    "reference": "string.Metin.735",
    "text": "Dosya adı bir dosya listesi ifadesine benziyor ancak yapılandırma seçeneği kapatılıyor.",
  },
  {
    "reference": "string.Metin.736",
    "text": "Arama ifadesi, Seçenekler sekmesinde belirtildiği gibi satır bazında bir satırda değerlendirildi.",
  },
  {
    "reference": "string.Metin.737",
    "text": "Çevreleyen çizgiler",
  },
  {
    "reference": "string.Metin.738",
    "text": "Çevreleyen çizgiler işaretleyici",
  },
  {
    "reference": "string.Metin.739",
    "text": "Hit Hatları",
  },
  {
    "reference": "string.Metin.740",
    "text": "Commas used in Wildcard expression, was semi-colon intended?",
  },
  {
    "reference": "string.Metin.741",
    "text": "Reparse noktası",
  },
  {
    "reference": "string.Metin.742",
    "text": "Güncelleme gerekli - dizin ayarları eşleşmiyor",
  },
  {
    "reference": "string.Metin.743",
    "text": "Dizin büyük/küçük harfe duyarlı aramaları desteklemez. Bu seçeneği etkinleştirmek Için büyük/küçük harfe duyarlı arama etkin olan dizini yeniden oluşturmanız gerekir.",
  },
  {
    "reference": "string.Metin.744",
    "text": "Aramayı başlatılamıyor",
  },
  {
    "reference": "string.Metin.745",
    "text": "Match durumda açık",
  },
  {
    "reference": "string.Metin.746",
    "text": "Dizin güncel değil, arama eski dizin ayarlarını kullanarak çalıştırıldı.",
  },
  {
    "reference": "string.Metin.747",
    "text": "Dosya için hit görüntülenemiyor.",
  },
  {
    "reference": "string.Metin.748",
    "text": "Arama tamamlanmadan önce durduruldu",
  },
  {
    "reference": "string.Metin.749",
    "text": "Boş dizin",
  },
  {
    "reference": "string.Metin.750",
    "text": "Hiç",
  },
  {
    "reference": "string.Metin.751",
    "text": "Dizin boş, dizin oluşturmak için dizin Yöneticisi'ni kullanın.",
  },
  {
    "reference": "string.Metin.752",
    "text": "Hariç tutulan Binary dosyalar",
  },
  {
    "reference": "string.Metin.753",
    "text": "Benzersiz Anahtar Kelimeler",
  },
  {
    "reference": "string.Metin.754",
    "text": "Geçersiz tarih. Bir sistem dosyası süresi 1601'den önce olamaz.",
  },
  {
    "reference": "string.Metin.755",
    "text": "Dosya yalnızca kısmen belirtilen maksimum aşan bulunan satır sayısı nedeniyle arandı.",
  },
  {
    "reference": "string.Metin.756",
    "text": "Filelist işleci işleme bir hata oluşturdu",
  },
  {
    "reference": "string.Metin.757",
    "text": "Renk",
  },
  {
    "reference": "string.Metin.758",
    "text": "Başka...",
  },
  {
    "reference": "string.Metin.759",
    "text": "Arama konuları",
  },
  {
    "reference": "string.Metin.760",
    "text": "Eylemi Onayla",
  },
  {
    "reference": "string.Metin.761",
    "text": "Bu mesajı tekrar gösterme",
  },
  {
    "reference": "string.Metin.762",
    "text": "Uyarı: Büyük dosya",
  },
  {
    "reference": "string.Metin.763",
    "text": "Seçilen dosya çok büyük ve programın yavaşlamasına veya yanıt vermeyi bırakmasına neden olabilir.",
  },
  {
    "reference": "string.Metin.764",
    "text": "** DOSYA YÜKÜ İPTAL EDİLDİ **",
  },
  {
    "reference": "string.Metin.765",
    "text": "Detay göster >>",
  },
  {
    "reference": "string.Metin.766",
    "text": "<< Ayrıntı gizle",
  },
  {
    "reference": "string.Metin.767",
    "text": "Bu özellik çalışması için program Internet Explorer'da 3. taraf tarayıcı uzantılarını etkinleştirmeniz gerekir ve yürürlüğe girmeden önce yeniden başlatmanız gerekir. 

Devam etmek ister misin?",
  },
  {
    "reference": "string.Metin.768",
    "text": "Belirtilen dizin yok.",
  },
  {
    "reference": "string.Metin.769",
    "text": "Dizin işlemi belirtilmedi.",
  },
  {
    "reference": "string.Metin.770",
    "text": "Süre (secs)",
  },
  {
    "reference": "string.Metin.771",
    "text": "Arama konuları",
  },
  {
    "reference": "string.Metin.772",
    "text": "İptal",
  },
  {
    "reference": "string.Metin.773",
    "text": "Şu anda bu arama için çalışan hiçbir içerik arama konuları",
  },
  {
    "reference": "string.Metin.774",
    "text": "Dizin için hiçbir yerleri belirtilmedi. Lütfen hangi konumların dizine ekleneceğini belirtin.",
  },
  {
    "reference": "string.Metin.775",
    "text": "Hiçbir içerik dizin belirtilmedi. Lütfen dizine hangi dosyaların dahil edilmesi gerektiğini belirtin.",
  },
  {
    "reference": "string.Metin.776",
    "text": "Dizin listesi başka bir uygulama tarafından güncelleştirmeleri için kilitlenir",
  },
  {
    "reference": "string.Metin.777",
    "text": "Finis'e 'çıkın' yazın.",
  },
  {
    "reference": "string.Metin.778",
    "text": "Dizin Yöneticisi başlatılamıyor",
  },
  {
    "reference": "string.Metin.779",
    "text": "Kısmi arama sonuçlarını tamamlama...",
  },
  {
    "reference": "string.Metin.780",
    "text": "Bulanık",
  },
  {
    "reference": "string.Metin.781",
    "text": "Dizin veritabanını depolamak için seçilen konum yeni veya boş bir klasör olmalıdır.",
  },
  {
    "reference": "string.Metin.782",
    "text": "Geçerli işlem ile ilgili bir sorun oluştu. Bu, normalde kullanıcı arabirimi ayarlarında 'bireysel görev çubuğu sekmesi önizlemeleri' ayarından kaynaklanmaktadır. Bu bir sorun olmaya devam ederse lütfen bu seçeneği kapatın.",
  },
  {
    "reference": "string.Metin.783",
    "text": "Dizin yeniden oluşturma",
  },
  {
    "reference": "string.Metin.784",
    "text": "Güncelleme dizini",
  },
  {
    "reference": "string.Metin.785",
    "text": "Yeni dizin oluşturma",
  },
  {
    "reference": "string.Metin.786",
    "text": "Dizin adı belirtilmedi.",
  },
  {
    "reference": "string.Metin.787",
    "text": "Dizin yolu belirtilmedi.",
  },
  {
    "reference": "string.Metin.788",
    "text": "Bir arama sırasında ölçüt türünü değiştirirseniz, geçerli arama iptal edilir. Geçerli aramayı iptal etmek istiyor musunuz?",
  },
  {
    "reference": "string.Metin.789",
    "text": "Dizin",
  },
  {
    "reference": "string.Metin.790",
    "text": "Yol, etkin hariç tutma yolları ve/veya filtreler nedeniyle aramaktan hariç tutuldu",
  },
  {
    "reference": "string.Metin.791",
    "text": "Boş dosya, aranabilir metin bulunamadı",
  },
  {
    "reference": "string.Metin.792",
    "text": "İfadeyi bireysel terimlere ayırılamıyor",
  },
  {
    "reference": "string.Metin.793",
    "text": "Belirtilen boş dosya listesi",
  },
  {
    "reference": "string.Metin.794",
    "text": "İfade türü, birden çok arama terimini desteklemek için Boolean olarak değiştirildi.",
  },
  {
    "reference": "string.Metin.795",
    "text": "Büyük ifade",
  },
  {
    "reference": "string.Metin.796",
    "text": "Dizin oluşturma işlemi başarısız oldu.",
  },
  {
    "reference": "string.Metin.797",
    "text": "Dizin Deposu",
  },
  {
    "reference": "string.Metin.798",
    "text": "İçerik Sınıfı",
  },
  {
    "reference": "string.Metin.799",
    "text": "Seçilen öğeleri kalıcı olarak silmek ister misiniz?",
  },
  {
    "reference": "string.Metin.800",
    "text": "Öğeleri silme",
  },
  {
    "reference": "string.Metin.801",
    "text": "Bir veya daha fazla çok büyük metin satırı, arama vuruşlarında bir etkiye sahip olabilecek daha kısa çizgilere bölünmüştür.",
  },
  {
    "reference": "string.Metin.802",
    "text": "Yeniden adlandırma başarısız oldu. Dosya kilitli olmadığını kontrol edin.",
  },
  {
    "reference": "string.Metin.803",
    "text": "Dizin listesi yükleniyor",
  },
  {
    "reference": "string.Metin.804",
    "text": "Varolan bir dizine başvuru ekleme",
  },
  {
    "reference": "string.Metin.805",
    "text": "Yazarlar",
  },
  {
    "reference": "string.Metin.806",
    "text": "Belge Anahtar Kelimeleri",
  },
  {
    "reference": "string.Metin.807",
    "text": "Yorumlar",
  },
  {
    "reference": "string.Metin.808",
    "text": "Başlık",
  },
  {
    "reference": "string.Metin.809",
    "text": "Sahip",
  },
  {
    "reference": "string.Metin.810",
    "text": "Dizin yolu ve Adı eşleşmiyor",
  },
  {
    "reference": "string.Metin.811",
    "text": "Dizini Kaldır",
  },
  {
    "reference": "string.Metin.812",
    "text": "Liste dizinleri",
  },
  {
    "reference": "string.Metin.813",
    "text": "Son Kaydeten",
  },
  {
    "reference": "string.Metin.814",
    "text": "Dizini sil",
  },
  {
    "reference": "string.Metin.820",
    "text": "Sıfır Hit Anahtar Kelimeler",
  },
  {
    "reference": "string.Metin.821",
    "text": "Kelime %s sadece profesyonel sürümde mevcuttur. Sadece terim için arıyorsanız "%s" sonra tırnak içine alın lütfen.",
  },
  {
    "reference": "string.Metin.822",
    "text": "Sabit süreli lisans. Kalan günler:",
  },
  {
    "reference": "string.Metin.823",
    "text": "Doğrudan Erişim",
  },
  {
    "reference": "string.Metin.824",
    "text": "Yorumlanmış metin",
  },
  {
    "reference": "string.Metin.825",
    "text": "Dönüştürülen metin",
  },
  {
    "reference": "string.Metin.826",
    "text": "IFiltre metni",
  },
  {
    "reference": "string.Metin.827",
    "text": "Önbelleğe alınmış metin",
  },
  {
    "reference": "string.Metin.828",
    "text": "Metin dosyası",
  },
  {
    "reference": "string.Metin.829",
    "text": "Raw dosya verileri",
  },
  {
    "reference": "string.Metin.830",
    "text": "İçerik Okuyucu",
  },
  {
    "reference": "string.Metin.831",
    "text": "İlk kez kullanım için program hazırlama...",
  },
  {
    "reference": "string.Metin.832",
    "text": "Deneme süresi doldu.",
  },
  {
    "reference": "string.Metin.833",
    "text": "Bu özellik programın ücretsiz sürümünde mevcut değildir.",
  },
  {
    "reference": "string.Metin.834",
    "text": "Profesyonel Deneme",
  },
  {
    "reference": "string.Metin.835",
    "text": "Profesyonel",
  },
  {
    "reference": "string.Metin.836",
    "text": "Lite",
  },
  {
    "reference": "string.Metin.837",
    "text": "Azaltılmış işlevsellik sürümü, bazı özellikler gizli veya devre dışı bırakılacaktır. Hem kişisel hem de ticari kullanım için ücretsiz.",
  },
  {
    "reference": "string.Metin.838",
    "text": "Tam fonksiyonel versiyonu.",
  },
  {
    "reference": "string.Metin.839",
    "text": "Deneme süresi için tamamen işlevsel sürümü.",
  },
  {
    "reference": "string.Metin.840",
    "text": "KAYITLI DEĞİL! 
Bu ürün sadece evde kişisel kullanım için lisanslıdır. 

Ticari Kullanıcılar:

Bu ürünü ticari bir ortamda kullanmaya devam etmek için KAYDETTİRMENİZ gerekir, aksi takdirde kullanıcı sözleşmesinin şartlarını ve koşullarını ihlal edersiniz.

Ücretsiz kayıt kodu için lütfen gidin to:
https://www.mythicsoft.com/agentransack/register",
  },
  {
    "reference": "string.Metin.841",
    "text": "Kaydedilmemiş. 
Bu ürünün ticari kullanıcıları, deneme süresi bittikten sonra kayıt yaptırmaları gerekmektedir.

Ücretsiz kayıt kodu için lütfen gidin to:
https://www.mythicsoft.com/agentransack/register",
  },
  {
    "reference": "string.Metin.842",
    "text": "Lütfen ürünü nasıl kullandığınızı belirtin.",
  },
  {
    "reference": "string.Metin.843",
    "text": "Ürünü yeniden başlattığınızda değişiklikler yürürlüğe girer.",
  },
  {
    "reference": "string.Metin.844",
    "text": "Girilen kayıt kodu ürünün Lite sürümü içindir, bu nedenle bazı özellikler artık devre dışı bırakılacaktır.",
  },
  {
    "reference": "string.Metin.845",
    "text": "Programın ücretsiz sürümü özelliği desteklemez: %s",
  },
  {
    "reference": "string.Metin.846",
    "text": "Hızla",
  },
  {
    "reference": "string.Metin.847",
    "text": "Orta",
  },
  {
    "reference": "string.Metin.848",
    "text": "Özel",
  },
  {
    "reference": "string.Metin.849",
    "text": "Arama yolu açılamıyor",
  },
  {
    "reference": "string.Metin.899",
    "text": "MS Office Geçici Dosyalarını Hariç Tut",
  },
  {
    "reference": "string.Metin.900",
    "text": "Konum filtreleri",
  },
  {
    "reference": "string.Metin.901",
    "text": "Göreli tarih/saatler",
  },
  {
    "reference": "string.Metin.902",
    "text": "Gelişmiş dönem eşleştirme",
  },
  {
    "reference": "string.Metin.903",
    "text": "Dosya Listeleri",
  },
  {
    "reference": "string.Metin.904",
    "text": "Çalışma alanları/oturumlar",
  },
  {
    "reference": "string.Metin.905",
    "text": "Gelişmiş çıkış biçimleri",
  },
  {
    "reference": "string.Metin.906",
    "text": "Anahtar kelime raporları",
  },
  {
    "reference": "string.Metin.907",
    "text": "Tarih/saat uzaklık kümeleri",
  },
  {
    "reference": "string.Metin.908",
    "text": "Konum Makroları",
  },
  {
    "reference": "string.Metin.909",
    "text": "Toplu kopyalama",
  },
  {
    "reference": "string.Metin.910",
    "text": "%APP_NAME% ilk kurulum gerektirir. Lütfen kurulumu tamamlamak için ana%APP_NAME% uygulamasını çalıştırın ve yeniden deneyin.",
  },
  {
    "reference": "string.Metin.911",
    "text": "Dosya Arama Kullanıcı tarafından iptal edildi",
  },
  {
    "reference": "string.Metin.912",
    "text": "Yeniden Başlat",
  },
  {
    "reference": "string.Metin.913",
    "text": "Kalıcı dosya adı filtresi",
  },
  {
    "reference": "string.Metin.914",
    "text": "EXE, DLL, SYS dosyalarını hariç tut",
  },
  {
    "reference": "string.Metin.915",
    "text": "Uyarılar/hata bildirdi bkz: Özet daha fazla bilgi için",
  },
  {
    "reference": "string.Metin.916",
    "text": "Yeni dizin yaratılamıyor. Lütfen bu dosyaya erişim hakkınız olduğunu kontrol edin: ",
  },
  {
    "reference": "string.Metin.917",
    "text": "Geçersiz bileşik dosya",
  },
  {
    "reference": "string.Metin.918",
    "text": "Geçersiz bileşik dosya, yerine standart arama kullanılıyor.",
  },
  {
    "reference": "string.Metin.919",
