  },
  {
    "reference": "dialog.IDD_BASIC.6",
    "text": "&Unterordner suchen",
  },
  {
    "reference": "dialog.IDD_BASIC.7",
    "text": "&Durchsuchen …",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.caption",
    "text": "Dateiname",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.1",
    "text": "Wie heisst die Datei die Sie finden möchten?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.2",
    "text": "Sie kennen den genauen Namen nicht? Keine Sorge, Sie können mit Teilen des Namens suchen. Wenn Sie keinen Teil des Namens kennen lassen Sie es leer.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.3",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.4",
    "text": "Mein*Doc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.5",
    "text": "Findet alle Dokumente die „Mein” und dann „Doc” an einer anderen Stelle im Namen haben",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.6",
    "text": "(z.B. Mein_Document.doc, Mein_Autodoc.txt usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.7",
    "text": "Stellen Sie sicher, dass der Dateiname im Tab „Optionen” auf „Dateimasken-Ausdruck” festgelegt ist, bevor Sie Ausdrücke wie die in den Beispielen gezeigten verwenden.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.8",
    "text": "MeinDoc",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.9",
    "text": "Findet alle Dokumente mit „MeinDok” irgendwo im Namen",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.10",
    "text": "(z.B. MeinDokument.doc, Note_From_MeinDoktor.txt usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.11",
    "text": "*.doc;*.txt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.12",
    "text": "Findet alle .doc oder .txt Dateien",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_NAME.13",
    "text": "(z.B. MeinDokument.doc, MeinDoktorsNote.txt usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.caption",
    "text": "Dateiort",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.1",
    "text": "&Alle lokalen Festplatten",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.2",
    "text": "Bestimmte &Laufwerke (z.B. C:, D: usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.3",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.4",
    "text": "Bestimmter &Ordner (z.B. C:\Windows, D:\Dateien\Meine Dokumente usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.5",
    "text": "",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.6",
    "text": "&Durchsuchen …",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.7",
    "text": "&Ja, ebenfalls die Unterordner durchsuchen",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.8",
    "text": "&Nein, ausschließlich diesen Ordner durchsuchen",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.9",
    "text": "&Die Suche automatisch beginnen nach Klick auf die Schaltfläche „Fertigstellen”",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.10",
    "text": "Wo möchten Sie nach der Datei suchen?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.11",
    "text": "Möchten Sie die Unterordner des Ordners ebenfalls durchsuchen?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_LOCATION.12",
    "text": "Leistungstipp: Die Auswahl eines bestimmten Ordners verringert die Anzahl der zu durchsuchenden Dateien stark und ist somit viel schneller.",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.caption",
    "text": "Dateiinhalt",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.1",
    "text": "Mächten Sie nach der Datei aufgrund von Text innerhalb der Datei suchen?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.2",
    "text": "&Nein, nur nach Dateinamen suchen",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.3",
    "text": "&Ja, den Inhalt der Datei durchsuchen",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.4",
    "text": "Welchen Text sollte die Datei beinhalten?",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.5",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.6",
    "text": ""Lieber Bill"",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.7",
    "text": "Findet jede Datei die eine Zeile mit der Phrase „Lieber Bill” enthält .",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.8",
    "text": "(z.B. Mein Lieber Bill …, Lieber Billy wie geht es dir … usw.)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.9",
    "text": "Lieber.*Bill",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.10",
    "text": "Findet jede Datei die eine Zeile mit beiden Worten „Lieber” und „Bill” enthält (z.B. Lieber Fred wie geht es Bill …, Die liebsten Gegenstände sollten erneut berechnet werden …)",
  },
  {
    "reference": "dialog.IDD_SEARCH_WIZ_CONTENTS.11",
    "text": "Leistungstipp: Den Inhalt einer Datei zu durchsuchen kann lange dauern, besonders wenn ein Name nicht eingegeben wurde oder nicht sehr genau ist. Daher ist es viel schneller „Nein” zu wählen.",
  },
  {
