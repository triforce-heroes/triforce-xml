  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.caption",
    "text": "Dateimaskenausdrücke",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.1",
    "text": "Dateimaskenausdrücke verwenden die Standard-Windows-Syntax für die Angabe einer Gruppe von Dateien. Ein Semikolon wird verwendet, um mehrere Ausdrücke voneinander zu trennen.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.2",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.3",
    "text": "*.txt			–––→	Sucht alle Dateien, die dem Dateityp .TXT entsprechen

*.xls;*.doc		–––→	Sucht alle Dateien, die dem Dateityp .XLS oder .DOC entsprechen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.4",
    "text": "Erweiterte Beispiele:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_DOSEXPR.5",
    "text": "*.png;*.jpg:Urlaub	–––→	Sucht alle PNG- und JPG-Dateien mit dem Wort „Urlaub” in deren Namen

NOT:*.doc;*.xls		–––→	Sucht alle Dateien, außer DOC- und XLS-Dateien

Urlaub;NOT:*.exe;*.dll	–––→	Sucht alle Dateien, außer EXE- oder DLL-Dateien mit dem Wort „Urlaub”
				in deren Dateinamen",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.caption",
    "text": "Modul für boole'sche Ausdrücke",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.1",
    "text": "Boole'sche Ausdrücke verwenden Suchoperatoren im Webstil wie UND, ODER, NICHT, WIE und NAHE. Boole'sche Suchen können nach Zeilen oder nach Dateien sein:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.2",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.3",
    "text": "Arbeit UND Dokument	–––→	Sucht nach den Wörtern „Arbeit” und „Dokument” in derselben Zeile/Datei",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.4",
    "text": "Arbeit Dokument	–––→	Führt dieselbe Suche wie oben durch (das UND ist eingeschlossen)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.5",
    "text": "Arbeit ODER Dokument	–––→	Sucht nach den Worten „Arbeit” ODER „Dokument” in derselben Zeile/Datei",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.6",
    "text": "Arbeit NAHE Dokument	–––→	Sucht nach „Arbeit” nahe dem Wort „Dokument” in einer Zeile/Datei",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.7",
    "text": ""Arbeit Dokument"	–––→	Sucht nach der genauen Phrase „Arbeit Dokument”",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.8",
    "text": "Zeilenweise",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.9",
    "text": "Ausdruck wird gegen jede individuelle Zeile getrennt geprüft",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.10",
    "text": "Dateiweise",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.11",
    "text": "Ausdruck wird über die ganze Datei geprüft",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR.12",
    "text": "Hinweis: Verwenden Sie Klammern um Ausdrücke zu gruppieren, z.B. (Arbeit UND doc) ODER (spezial UND Fall)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.caption",
    "text": "Modul für Boole'sche Ausdrücke",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.1",
    "text": "Boole'sche Ausdrücke verwenden die Suchoperatoren UND, ODER und NICHT. Boole'sche Suchen werden über die gesamte Datei abgeglichen.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.2",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.3",
    "text": "Arbeit UND Dokument	–––→	sucht die Wörtern „Arbeit” und „Dokument” innerhalb derselben Datei.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.4",
    "text": "Arbeit Dokumentt	–––→	führt die identische Suche wie oben durch (das UND ist eingeschlossen)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.5",
    "text": "Arbeit ODER Dokument	–––→	sucht die Wörtern „Arbeit” ODER „Dokument” innerhalb derselben Datei",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.6",
    "text": "Arbeit NICHT Dokument	–––→	sucht nach „Arbeit”, jedoch ohne das Wort „Dokument” innerhalb derselben Datei",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.7",
    "text": ""Arbeits Dokument"	–––→	sucht nach dem exakten Ausdruck „Arbeit Dokument”",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.8",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.9",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.10",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.11",
    "text": "",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_BOOLEANEXPR_LITE.12",
    "text": "Hinweis: Verwenden Sie Klammern, um Ausdrücke zu gruppieren, z.B. (arbeit UND doc) ODER (spezial UND fall)",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.caption",
    "text": "Einfacher Text",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.1",
    "text": "Reiner Text behandelt den eingegebenen Suchkriterientext als Literalwert, d.h. genau wie der Text im Bearbeitungsfeld eingegeben ist. Die Suchkriterien werden mit dem ganzen oder dem Teil eines Wortes verglichen.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.2",
    "text": "Beispiele:",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.3",
    "text": "der Autor	–––→	Findet Phrasen wie „der Autor” oder „der Autoreifen”.",
  },
  {
    "reference": "dialog.IDD_EXPR_WIZ_EXACTEXPR.4",
    "text": "fisch		–––→	Findet auch „Fisch”, „Fischen”, oder „abfischen”.",
  },
